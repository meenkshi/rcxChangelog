{% if settings.bttt_enable %} 

{% assign vertical_offset_for_trigger = settings.bttt_trigger %}
{% assign position_from_bottom = '1.3em' %}

<style>
  .back-to-top{position:fixed;display:none;bottom:{{ settings.bttt_bottom_mobile }}px;right:{{ settings.bttt_right_mobile }}px;z-index:9999999999}
  .back-to-top:hover{text-decoration:none}
  .back-to-top svg {width:{{ settings.bttt_size_mobile }}px;height:{{ settings.bttt_size_mobile }}px;box-shadow: 0 0 3px 0px white;border-radius: 100%;}
  @media screen and (min-width: 1100px) {
    .back-to-top{bottom:{{ settings.bttt_bottom_desk }}px;right:{{ settings.bttt_right_desk }}px; border-radius:100%}
    .back-to-top svg{width:{{ settings.bttt_size_desk }}px;height:{{ settings.bttt_size_desk }}px}
  }
</style>

<a href="#" class="back-to-top">
  <svg width="45" height="45" viewBox="0 0 24 24"><path fill="none" d="M12.2 7.6c-.1-.2-.4-.2-.6 0l-5.9 5.9c-.4.4-.4 1.1 0 1.5l.2.2c.4.4 1.1.4 1.5 0l4.2-4.2c.2-.2.5-.2.7 0l4.2 4.2c.4.4 1.1.4 1.5 0l.3-.2c.4-.4.4-1.1-.2-1.5l-5.9-5.9z"/><path fill="{{ settings.bttt_bgcolor }}" d="M10.5.2C5.2.9.9 5.2.2 10.5-.8 18.3 5.8 25 13.7 24c5.3-.7 9.7-5 10.3-10.3C25 5.9 18.4-.8 10.5.2z"/><path fill="{{ settings.bttt_color }}" d="M18.3 14.9c-.6.4-1 .5-1.8-.3l-4.2-4.2c-.2-.2-.6-.2-.7-.1l-4.2 4.2c-.6.7-1.1 1.1-1.7.5-.5-.5-.5-1 0-1.5l5.9-5.9c.2-.2.5-.2.6 0l5.9 5.9c.5.5.8.9.2 1.4z"/></svg>
</a>

<script>
  addEventListener("load", function(){
    jQuery(function($) {
      var offset = {{ vertical_offset_for_trigger }};
      var duration = 250;
      $(window).scroll(function() {
        if ($(this).scrollTop() > offset) {
          $('.back-to-top').fadeIn(duration);
        } 
        else {
          $('.back-to-top').fadeOut(duration);
        }
      });
      $('.back-to-top').unbind('click.smoothscroll').bind('click', function(e) {
        e.preventDefault();
        $('html, body').animate( { scrollTop: 0 }, duration);
        return false;
      })
    });
  });
</script>
  {% endif %}