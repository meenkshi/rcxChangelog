      }
    
       //post add to cart request when ATC button is rendered
       var waitForAtc = setInterval(function () {
        atcBtn = document.querySelectorAll('{{ section.blocks[developer].settings.selector_atc }}')
        atcBtn.forEach(btn => {
          if (btn !== null) {
            clearInterval(waitForAtc);
            if(packAvailability[0].getAttribute('data-variant-available') == 0){btn.disabled = true} else {btn.disabled = false}
            btn.addEventListener('click', submit)
            function submit(e) {
              e.preventDefault();
              e.stopImmediatePropagation()            
              let selectedPack = document.querySelector('.packsUpsell-block input[name="pack-upsell"]:checked')
              let selectedPackValue = selectedPack.value
              let propertiesNode = selectedPack.parentElement.parentElement.nextElementSibling
              let quantityValue = quantityNode ? quantityNode.value : 1
              var textParams = `{"quantity":${quantityValue}, "id": ${selectedPackValue}}`  
              {% if section.settings.atc_action == 'original' %}
                let inputEl = document.querySelectorAll('.packOptions_input') 
                if(inputEl[0]) {inputEl.forEach(function(input) {input.parentNode.removeChild(input)})}
                if(propertiesNode) {
                  let properties = propertiesNode.querySelectorAll('.packsUpsell__properties select')
                  properties.forEach(property => {btn.insertAdjacentHTML('beforebegin', `<input class="packOptions_input" type="hidden" name="properties[${property.previousElementSibling.innerText}]" value="${property.value}">`)})
                }
                btn.removeEventListener('click', submit)
                btn.click();
                btn.addEventListener('click', submit)
              {% else %}
                {% if section.settings.atc_action != 'custom' %}
                  if(propertiesNode) {
                    let properties = propertiesNode.querySelectorAll('.packsUpsell__properties select')
                    var dict = []
                    properties.forEach(property => {dict.push({[property.previousElementSibling.innerText] : property.value})})
                    let productProperties = JSON.stringify(dict)
                    productProperties = productProperties.replace(/[\{\}\[\]]/gi, '')
                    textParams = `{"quantity":${quantityValue}, "id": ${selectedPackValue}, "properties":{${productProperties}}}`
                  }
                  var http = new XMLHttpRequest()
                  var url = '/cart/add.js'
                  var params = textParams
                  http.open('POST', url, true)
                  http.setRequestHeader('Content-type', 'application/json;charset=UTF-8')
                  http.onreadystatechange = function() {
                    if (http.readyState == 4) {
                      if (http.status == 200) {
                        {% if section.settings.atc_action == 'cart' %}window.location = '/cart';{% else %}window.location = '/checkout';{% endif %}
                      } else {
                        alert("Désolé, ce produit ne peut pas être ajouté au panier. Contactez-nous pour plus d'informations.")
                      }
                    }
                  }
                  http.send(params)
                {% else %}
                  if(propertiesNode) {
                    let properties = propertiesNode.querySelectorAll('.packsUpsell__properties select')
                    var dict = []
                    properties.forEach(property => {dict.push({[property.previousElementSibling.innerText] : property.value})})
                    let productProperties = JSON.stringify(dict)
                    productProperties = productProperties.replace(/[\{\}\[\]]/gi, '')
                    textParams = `{"quantity":${quantityValue}, "id": ${selectedPackValue}, "properties":{${productProperties}}}`
                  }
                  document.querySelector('#packOptions-maxdesign-items').innerHTML = `{"quantity":1, "id": ${selectedPackValue}, "properties":{${productProperties}}}`
                  /* for ajax data :
                let textParams = document.querySelector('#packOptions-maxdesign-items').text
                let jsonParams = JSON.parse(textParams); */
                {% endif %}
              {% endif %}
            }
          }
        })
       }, 100)
      
      // observe input change & update DOM
      var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
          if (mutation.target.dataset.active == 'true') {
            let mutedPack = mutation.target.parentElement.parentElement
            let updatedPrice = mutation.target.dataset.variantPrice
            let updatedComparePrice = mutation.target.dataset.variantComparePrice
            let updatedInventory = mutation.target.dataset.variantInventory
            let updatedSavings = mutation.target.dataset.variantSavings
            let updatedImage = mutation.target.dataset.variantImage
            //update prices
            mutedPack.querySelector("span[data-variant-price]").textContent = updatedPrice
            console.log(updatedPrice)
            mutedPack.querySelector("span[data-variant-compare-price]").textContent = updatedComparePrice
            mainPriceAll.forEach((mainPrice) => {mainPrice.textContent = updatedPrice})
            document.getElementById("testpriceold" ).innerHTML = updatedComparePrice;
            document.getElementById("testprice" ).innerHTML = updatedPrice;
            mainComparePriceAll.forEach((mainComparePrice) => {mainComparePrice.textContent = updatedComparePrice})
            //update btn
            if(mutation.target.dataset.variantAvailable == 'true') {atcBtn.forEach(btn => {btn.disabled = false})} else {atcBtn.forEach(btn => {btn.disabled = true})}
            //update image
            mutedPack.querySelector('.packsUpsell-image > span').style.backgroundImage = `url("${updatedImage}")`
            //update savings & inventory
            if(mutedPack.querySelector('.packsUpsell-savings')){mutedPack.querySelector('.packsUpsell-savings').textContent = updatedSavings}
            if(mutedPack.querySelector('.packsUpsell-inventory') || document.querySelector('.product_left_counter')){
              {% unless virtual_stocks %}
              mutedPack.querySelector('.packsUpsell-inventory').textContent = updatedInventory
              /*cc*/if(document.querySelector('.product_left_counter')) {document.querySelector('.product_left_counter').textContent = updatedInventory}
              {% else %}
              getVirtualStocks(mutation.target.value, mutedPack.querySelector('.packsUpsell-inventory'), false, parseInt(mutedPack.parentElement.getAttribute('data-block-index')) - 1)
              {% endunless %}
            }
          }
        })
      })
      observer.observe(document.querySelector('.packsUpsell-tabs'), {attributes:true, attributeFilter: ['data-active'], childList:true, subtree: true})

   } init()

   //update inside Shopify editor
   document.addEventListener('shopify:section:select', function(evt) {
     init()
   })
  </script>
{% endif %}

