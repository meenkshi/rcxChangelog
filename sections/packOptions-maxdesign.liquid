  <script type="application/json" id="packOptions-maxdesign-items"></script>
  <script>  
    function init() {      
      //main variable selectors
      let formSubmit = document.querySelectorAll('{{ section.blocks[developer].settings.selector_form }}'), atcBtn
      let mainPriceAll = document.querySelectorAll('{{ section.blocks[developer].settings.selector_price }}')
      let mainComparePriceAll = document.querySelectorAll('{{ section.blocks[developer].settings.selector_compare_price }}')
      let quantityNode = document.querySelector('{{ section.blocks[developer].settings.selector_quantity }}')
      
      //main static selectors
      let packArray = [document.querySelector('.packsUpsell-block[data-block-index="1"]'), document.querySelector('.packsUpsell-block[data-block-index="2"]'), document.querySelector('.packsUpsell-block[data-block-index="3"]')]
      let packLabels = document.querySelectorAll('.packsUpsell-block > label')
      let packPrice = document.querySelectorAll('.packsUpsell-block input[data-variant-price]')
      let packComparePrice = document.querySelectorAll('.packsUpsell-block [data-variant-compare-price]')
      let packAvailability = document.querySelectorAll('.packsUpsell-block [data-variant-available]')
      let inventory = document.querySelectorAll('.packsUpsell-block [data-variant-inventory]')
      let masterSelector = document.querySelector('select[name="id"]')
      let newOption = document.createElement("option")
      var description = packLabels[0].parentElement.querySelector('aside')
	  
      //update prices on load & vstocks
      mainPriceAll.forEach((mainPrice) => {mainPrice.textContent = packArray[0].querySelector("span[data-variant-price]").textContent})
      mainComparePriceAll.forEach((mainComparePrice) => {mainComparePrice.textContent = packArray[0].querySelector("span[data-variant-compare-price]").textContent})
      /*cc*/{% unless virtual_stocks %}if(document.querySelector('.product_left_counter')) {document.querySelector('.product_left_counter').textContent = inventory[0].getAttribute('data-variant-inventory')}{% endunless %}
      
      
      {%- if virtual_stocks -%}
      //define product handles and stock arrays
      let decrement, vStocksDefault, vStocksTrue, vStocksDefaultMin, vStocksDefaultMax, evalDecrement;
      let variantsID = [{{ variants_id_1 | default: '[]' }}, {{ variants_id_2 | default: '[]' }}, {{ variants_id_3 | default: '[]' }}];
      let vStocks = [{{ virtual_stocks_1 | default: '[]' }}, {{ virtual_stocks_2 | default: '[]' }}, {{ virtual_stocks_3 | default: '[]' }}];
      let masterDict = {
        variantsID: [variantsID[0], variantsID[1], variantsID[2]],
        vStocks: [vStocks[0], vStocks[1], vStocks[2]]
      }
      let vStocksVisits = {{ virtual_stocks_visits | default: false }}
      let pageLoad = true
      
      //fetch Dict in storage if it exist
      masterDict = localStorage.getItem("vStocks") !== null && vStocksVisits ? JSON.parse(localStorage.getItem("vStocks")) : masterDict   
      
      function vStocksDecrement(newVisit, valueToDecrement) {
        if(!vStocksVisits && newVisit) {
          let currentDate = new Date()
          let timeToday = (currentDate.getTime() - currentDate.setHours({{ section.settings.virtual_stocks_start }},0,0,0))/1000/60/60/24
          let timeTodayMin = timeToday < 0 ? 0 : timeToday
          let decrement = Math.round(valueToDecrement*timeTodayMin)
          return decrement; 
        } else if(newVisit && ("time" in masterDict)) {
          //check last time it was updated
          let timeTreshold = {{ section.settings.virtual_stocks_interval }}
          let timeDiff = +new Date - masterDict.time
          let timeDiffMns = Math.floor(timeDiff / 1000)
          if(timeDiffMns >= timeTreshold) {
            return Math.floor(Math.random() * 2) + 1;
          } else {
            return 0;
          }
        } else {
          return 0;
        }
      }
	 
      //push new key/values in Dict if they don't exist
      function isArrayInArray(x, check) {var result = x.find(function(ele) {return (JSON.stringify(ele) === JSON.stringify(check))});return result !=null}
      for (var i = 0, n = variantsID.length; i < n; i++) {if(!isArrayInArray(masterDict.variantsID, variantsID[i])){masterDict.variantsID.push(variantsID[i]);masterDict.vStocks.push(vStocks[i])}}
      
      //decrement virtual stock in Dom & update storage
      function getVirtualStocks(packID, inventoryNode, newVisit, packIndex) {
        let firstVariant = newVisit ? true : false;
        //loop through all set of product variants
        for (var i = 0, m = masterDict.variantsID.length; i < m; i++) {
          let variantsID = masterDict.variantsID[i]
          let packIDinVariantsID = variantsID.includes(+packID)
		  //loop through current product variants  
          for (var j = 0, v = variantsID.length; j < v; j++) {
            //decrement variant max vStocks
            vStocksDefault = masterDict.vStocks[i][j]
            vStocksTrue = vStocksDefault.includes('-')
            vStocksDefaultMin = vStocksTrue ? +vStocksDefault.split('-')[0] : vStocksDefault
            vStocksDefaultMax = vStocksTrue ? +vStocksDefault.split('-')[1] - vStocksDecrement(newVisit, +vStocksDefault.split('-')[1]) : vStocksDefault
            //if vStocks can be decremented on newVisit & enabled & packID belongs to array of variants
            if(vStocksDefaultMax >= vStocksDefaultMin && vStocksTrue && packIDinVariantsID) {
              //write first vstock value on load
              if(newVisit && firstVariant) {
                console.log(vStocksDefaultMax);
                if(inventoryNode) {inventoryNode.textContent = vStocksDefaultMax;}firstVariant=false;
                /*cc*/if(document.querySelector('.product_left_counter') && pageLoad) {pageLoad = false;document.querySelector('.product_left_counter').textContent = vStocksDefaultMax}
              } 
              //else if variant change & updated packID matches array value  
              else if(!newVisit && !firstVariant && variantsID[j] == packID) {
                if(inventoryNode) {inventoryNode.textContent = vStocksDefaultMax;}
                /*cc*/if(document.querySelector('.product_left_counter')) {console.log('22');document.querySelector('.product_left_counter').textContent = vStocksDefaultMax}
              }
              //update Dict vStocks forEach variant on newVisit
              if(newVisit) {masterDict.vStocks[i][j] = `${vStocksDefaultMin}-${vStocksDefaultMax}`} 
            //else if vStocks disabled or can't be decremented & belongs to array of variants
            } else if(packIDinVariantsID) {
              //update min or default inventory value, then reset Dict vStocks for this variant (replaced i with packIndex)
              if(newVisit && firstVariant) {firstVariant=false}
              if(variantsID[j] == packID) {
                if(inventoryNode) {inventoryNode.textContent = vStocksDefaultMin}
                /*cc*/if(document.querySelector('.product_left_counter') && pageLoad || !newVisit) {document.querySelector('.product_left_counter').textContent = vStocksDefaultMin}
              }
              if(vStocksVisits) {
                masterDict.vStocks[i][j] = vStocks[packIndex][j]
              } else {
                if(newVisit) {masterDict.vStocks[i][j] = `${vStocksDefaultMin}-${vStocksDefaultMax}`}
              }
            }
          }
        }
      }
      
      //init vStocks on newVisit
      packLabels.forEach(function(pack, index) {
        let inventoryNode = pack.querySelector('.packsUpsell-inventory')
        if(inventoryNode || document.querySelector('.product_left_counter')) {getVirtualStocks(pack.querySelector('input').value, inventoryNode, true, index)}
      })
      
      //update time and reset vStocks storage
      masterDict.time = +new Date
      window.localStorage.setItem('vStocks', JSON.stringify(masterDict))
      {%- endif -%}
      
      
      //fix first slideDown animation
      if (description) {description.style.height = window.getComputedStyle(description, null).getPropertyValue("height")}

      //toggle active class & attributes to checked pack
      packLabels.forEach(pack => {
        pack.querySelector('input').addEventListener('input', function(checked) {
          let selectedPackValue = checked.target.value
          let selectedPackValueNode = document.querySelector(`.packsUpsell-input input[value="${selectedPackValue}"]:checked`)
          
          packLabels.forEach(el => {
            if(el.parentElement.classList.contains('active')) {el.parentElement.classList.remove('active')}
            if(el.querySelector('input').getAttribute('data-active') == 'true') {el.querySelector('input').setAttribute('data-active', 'false')}
            description = el.parentElement.querySelector('.packsUpsell-description')
            if (description && !checked.cancelable) {description.style.height = "0px"}
          })
          
          //update attribute to dispatch mutation observer & toggle description
          selectedPackValueNode.closest('.packsUpsell-block').classList.add('active')
          selectedPackValueNode.setAttribute('data-active', 'true')
          description = selectedPackValueNode.closest('.packsUpsell-block').querySelector('.packsUpsell-description')
          if (description && !checked.cancelable) {description.style.height = "auto";let height = description.offsetHeight + "px";description.style.height = "0px";setTimeout(function() {description.style.height = height}, 15)}
          
          //update main selector for express checkout buttons
		  newOption.value = selectedPackValue;
		  masterSelector.add(newOption); 
          masterSelector.value = selectedPackValue;
        })
      })

      //prevent form submission
      formSubmit.forEach(form => {
        form.addEventListener("submit", function(e){
          e.preventDefault()
          e.stopImmediatePropagation()
        })
      });
      
      //update pack dataset on variant change
      for(const [index, pack] of packArray.entries()) {
        if(pack) {
          pack.querySelectorAll('.packsUpsell__options select').forEach(function(option) {
            option.addEventListener('change', function() {
              var id = "",price = "",available = "",inventory = "",input = pack.querySelector('input'),image = "",comparePrice = "",savings = 0; 
              if(index == 0) {
                 {%- for option in upsell_product_1.options_with_values -%}var option_{{ forloop.index }}_1 = document.querySelector("#PackOptionSelector_{{ forloop.index }}_1").value;{%- endfor -%}
                 {%- for variant in upsell_product_1.variants -%}
                 if({%- for option in variant.options -%}option_{{ forloop.index }}_1 == "{{ option }}"{%- unless forloop.last -%} && {%- endunless -%}{%- endfor -%}) {id = {{ variant.id }};inventory = {{ variant.inventory_quantity }};image = "{{ variant.image | default: upsell_product_1.featured_image | img_url: 'small' }}";{% if variant.available %} price = "{{ variant.price | money }}";{% if section.blocks[index].settings.compareprice_upsell_1 and variant.compare_at_price != blank %}comparePrice = "{{ variant.compare_at_price | money }}";savings = {{ variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round }}{% else %}comparePrice = ""{% endif %};available = true;{% else %}price = "{{ section.blocks[developer].settings.product_unavailable }}";comparePrice = "";savings = 0;available = false;{% endif %}}
                 {%- endfor -%}  
              } else if(index == 1) {
                  {%- for option in upsell_product_2.options_with_values -%}var option_{{ forloop.index }}_2 = document.querySelector("#PackOptionSelector_{{ forloop.index }}_2").value;{%- endfor -%}
                  {%- for variant in upsell_product_2.variants -%}
                  if({%- for option in variant.options -%}option_{{ forloop.index }}_2 == "{{ option }}"{%- unless forloop.last -%} && {%- endunless -%}{%- endfor -%}) {id = {{ variant.id }};inventory = {{ variant.inventory_quantity }};image = "{{ variant.image | default: upsell_product_2.featured_image | img_url: 'small' }}";{% if variant.available %}price = "{{ variant.price | money }}";{% if section.blocks[index].settings.compareprice_upsell_2 and variant.compare_at_price != blank %}comparePrice = "{{ variant.compare_at_price | money }}";savings = {{ variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round }}{% else %}comparePrice = ""{% endif %};available = true;{% else %}price = "{{ section.blocks[developer].settings.product_unavailable }}";comparePrice = "";savings = 0;available = false;{% endif %}}
                  {%- endfor -%}
              } else if(index == 2) {
                  {%- for option in upsell_product_3.options_with_values -%}var option_{{ forloop.index }}_3 = document.querySelector("#PackOptionSelector_{{ forloop.index }}_3").value;{%- endfor -%}
                  {%- for variant in upsell_product_3.variants -%}
                  if({%- for option in variant.options -%}option_{{ forloop.index }}_3 == "{{ option }}"{%- unless forloop.last -%} && {%- endunless -%}{%- endfor -%}) {id = {{ variant.id }};inventory = {{ variant.inventory_quantity }};image = "{{ variant.image | default: upsell_product_3.featured_image | img_url: 'small' }}";{% if variant.available %}price = "{{ variant.price | money }}";{% if section.blocks[index].settings.compareprice_upsell_3 and variant.compare_at_price != blank %}comparePrice = "{{ variant.compare_at_price | money }}";savings = {{ variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round }}{% else %}comparePrice = ""{% endif %};available = true;{% else %}price = "{{ section.blocks[developer].settings.product_unavailable }}";comparePrice = "";savings = 0;available = false;{% endif %}}
                  {%- endfor -%}
              }
              input.value = id;input.setAttribute("data-variant-available", available);input.setAttribute("data-variant-inventory", inventory);input.setAttribute("data-variant-price", price);input.setAttribute("data-variant-compare-price", comparePrice);input.setAttribute("data-variant-savings", savings);input.setAttribute("data-variant-image",image);option.parentElement.parentElement.parentElement.previousElementSibling.querySelector('input').setAttribute('data-active', 'true');
              newOption.value = id;masterSelector.add(newOption);masterSelector.value = id;
            })
          })
