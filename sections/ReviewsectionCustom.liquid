{% comment %}
  RCXBuggy - Page Avis (Reviews Page) - Block Architecture
  Refactored for Responsiveness and Modular CSS.
{% endcomment %}

{% assign align = section.settings.section_alignment | default: 'center' %}
{% assign text_align_class = 'rcxbuggy-text-' | append: align %}

{% assign justify_class = 'rcxbuggy-justify-center' %}
{% assign items_class = 'rcxbuggy-items-center' %}

{% if align == 'left' %}
  {% assign justify_class = 'rcxbuggy-justify-start' %}
  {% assign items_class = 'rcxbuggy-items-start' %}
{% elsif align == 'right' %}
  {% assign justify_class = 'rcxbuggy-justify-end' %}
  {% assign items_class = 'rcxbuggy-items-end' %}
{% endif %}

<style>
  .rcxbuggy-wrapper * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .rcxbuggy-wrapper {
    font-family: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
    font-size: 16px;
    line-height: 1.5;
  }

  /* Color utilities */
  .rcxbuggy-bg-white { background-color: #ffffff; }
  .rcxbuggy-bg-gray-50 { background-color: #f9fafb; }
  .rcxbuggy-bg-gray-100 { background-color: #f3f4f6; }
  .rcxbuggy-bg-gray-200 { background-color: #e5e7eb; }
  .rcxbuggy-bg-gray-300 { background-color: #d1d5db; }
  .rcxbuggy-bg-blue-50 { background-color: #eff6ff; }
  .rcxbuggy-bg-blue-600 { background-color: #2563eb; }
  .rcxbuggy-bg-blue-500 { background-color: #3b82f6; }
  .rcxbuggy-bg-blue-700 { background-color: #1d4ed8; }
  .rcxbuggy-bg-green-100 { background-color: #dcfce7; }
  .rcxbuggy-bg-yellow-400 { background-color: #facc15; }
  .rcxbuggy-bg-gray-900 { color: #111827; }

  .rcxbuggy-text-white { color: #ffffff; }
  .rcxbuggy-text-gray-900 { color: #111827; }
  .rcxbuggy-text-gray-800 { color: #1f2937; }
  .rcxbuggy-text-gray-700 { color: #374151; }
  .rcxbuggy-text-gray-600 { color: #4b5563; }
  .rcxbuggy-text-gray-500 { color: #6b7280; }
  .rcxbuggy-text-gray-400 { color: #9ca3af; }
  .rcxbuggy-text-blue-600 { color: #2563eb; }
  .rcxbuggy-text-blue-700 { color: #1d4ed8; }
  .rcxbuggy-text-blue-100 { color: #dbeafe; }
  .rcxbuggy-text-green-800 { color: #166534; }

  /* Border utilities */
  .rcxbuggy-border { border-width: 1px; border-style: solid; }
  .rcxbuggy-border-gray-100 { border-color: #f3f4f6; }
  .rcxbuggy-border-gray-200 { border-color: #e5e7eb; }

  /* Border radius */
  .rcxbuggy-rounded { border-radius: 0.25rem; }
  .rcxbuggy-rounded-full { border-radius: 9999px; }
  .rcxbuggy-rounded-xl { border-radius: 0.75rem; }
  .rcxbuggy-rounded-2xl { border-radius: 1rem; }

  /* Shadow */
  .rcxbuggy-shadow-sm { box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05); }
  .rcxbuggy-shadow { box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1); }

  /* Spacing */
  .rcxbuggy-mx-auto { margin-left: auto; margin-right: auto; }
  .rcxbuggy-ml-1 { margin-left: 0.25rem; }

  .rcxbuggy-px-4 { padding-left: 1rem; padding-right: 1rem; }
  .rcxbuggy-px-2 { padding-left: 0.5rem; padding-right: 0.5rem; }
  .rcxbuggy-px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
  .rcxbuggy-px-5 { padding-left: 1.25rem; padding-right: 1.25rem; }
  .rcxbuggy-py-0-5 { padding-top: 0.125rem; padding-bottom: 0.125rem; }
  .rcxbuggy-py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
  .rcxbuggy-py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }

  .rcxbuggy-p-4 { padding: 1rem; }
  .rcxbuggy-p-6 { padding: 1.5rem; }
  .rcxbuggy-p-8 { padding: 4rem; }

  .rcxbuggy-pb-6 { padding-bottom: 1.5rem; }
  .rcxbuggy-pb-10 { padding-bottom: 2.5rem; }
  .rcxbuggy-pb-12 { padding-bottom: 3rem; }
  .rcxbuggy-pb-20 { padding-bottom: 5rem; }
  .rcxbuggy-pt-12 { padding-top: 3rem; }

  .rcxbuggy-mt-1 { margin-top: 0.25rem; }
  .rcxbuggy-mt-2 { margin-top: 0.5rem; }
  .rcxbuggy-mt-3 { margin-top: 0.75rem; }
  .rcxbuggy-mt-4 { margin-top: 1rem; }
  .rcxbuggy-mt-6 { margin-top: 1.5rem; }
  .rcxbuggy-mt-8 { margin-top: 4rem; }
  .rcxbuggy-mt-10 { margin-top: 2.5rem; }

  .rcxbuggy-mb-2 { margin-bottom: 0.1rem; }
  .rcxbuggy-mb-4 { margin-bottom: 1rem; }
  .rcxbuggy-mb-6 { margin-bottom: 1.5rem; }
  .rcxbuggy-mb-8 { margin-bottom: 4rem; margin-top:2rem}
  .rcxbuggy-mb-9 { margin-bottom: 2rem; margin-top:2rem}

  .rcxbuggy-gap-0-5 { gap: 0.125rem; }
  .rcxbuggy-gap-2 { gap: 0.5rem; }
  .rcxbuggy-gap-3 { gap: 0.75rem; }
  .rcxbuggy-gap-4 { gap: 1rem; }
  .rcxbuggy-gap-6 { gap: 1.5rem; }
  .rcxbuggy-gap-8 { gap: 2rem; }

  /* Spacing utilities for flex/grid */
  .rcxbuggy-space-y-1 > * + * { margin-top: 0.25rem; }
  .rcxbuggy-space-y-3 > * + * { margin-top: 0.75rem; }
  .rcxbuggy-space-y-4 > * + * { margin-top: 1rem; }
  .rcxbuggy-space-y-8 > * + * { margin-top: 2rem; }

  .rcxbuggy-space-x-minus-3 > * {
    margin-left: -0.75rem;
  }

  .rcxbuggy-space-x-minus-3 > *:first-child {
    margin-left: 0;
  }

  /* Typography */
  .rcxbuggy-text-xs { font-size: 12px; line-height: 16px; }
  .rcxbuggy-text-sm { font-size: 14px; line-height: 20px; }
  .rcxbuggy-text-base { font-size: 16px; line-height: 22px; }
  .rcxbuggy-text-lg { font-size: 18px; line-height: 28px; }
  .rcxbuggy-text-xl { font-size: 20px; line-height: 28px; }
  .rcxbuggy-text-2xl { font-size: 24px; line-height: 32px; }
  .rcxbuggy-text-3xl { font-size: 30px; line-height: 36px; }
  .rcxbuggy-text-4xl { font-size: 36px; line-height: 44px; }

  .rcxbuggy-font-medium { font-weight: 500; }
  .rcxbuggy-font-semibold { font-weight: 600; }
  .rcxbuggy-font-bold { font-weight: 700; }
  .rcxbuggy-font-extrabold { font-weight: 800; }

  .rcxbuggy-uppercase { text-transform: uppercase; }
  .rcxbuggy-tracking-tight { letter-spacing: -0.025em; }
  .rcxbuggy-tracking-widest { letter-spacing: 0.1em; }
  .rcxbuggy-leading-tight { line-height: 1.25; }

  .rcxbuggy-text-center { text-align: center; }
  .rcxbuggy-text-left { text-align: left; }
  .rcxbuggy-text-right { text-align: right; }
  
  /* Updated Typography for Pixel Perfection */
  .rcxbuggy-h1-hero { font-size: 48px; line-height: 48px; font-weight: 800; }
  .rcxbuggy-h2-section { font-size: 34px; line-height: 42px; font-weight: 800; }
  .rcxbuggy-h3-heading { font-size: 34px; line-height: 44px; font-weight: 800; }
  .my-responsive-title { font-size: 36px; font-weight: 800; }
  .rcxbuggy-text-lg2 { font-size: 18px; line-height: 28px; margin-bottom: 3px; }

  /* Layout utilities */
  .rcxbuggy-flex { display: flex; }
  .rcxbuggy-inline-flex { display: inline-flex; }
  .rcxbuggy-grid { display: grid; }
  .rcxbuggy-inline-block { display: inline-block; }
  .rcxbuggy-block { display: block; }

  .rcxbuggy-flex-col { flex-direction: column; }
  .rcxbuggy-flex-row { flex-direction: row; }
  .rcxbuggy-flex-shrink-0 { flex-shrink: 0; }
  .rcxbuggy-flex-wrap { flex-wrap: wrap; }

  .rcxbuggy-items-center { align-items: center; }
  .rcxbuggy-items-start { align-items: flex-start; }
  .rcxbuggy-items-end { align-items: flex-end; }
  .rcxbuggy-items-stretch { align-items: stretch; }
  .rcxbuggy-justify-between { justify-content: space-between; }
  .rcxbuggy-justify-center { justify-content: center; }
  .rcxbuggy-justify-start { justify-content: flex-start; }
  .rcxbuggy-justify-end { justify-content: flex-end; }

  .rcxbuggy-grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }

  .rcxbuggy-overflow-hidden { overflow: hidden; }

  .rcxbuggy-relative { position: relative; }
  .rcxbuggy-absolute { position: absolute; }
  .rcxbuggy-left-3 { left: 0.75rem; }
  .rcxbuggy-top-3 { top: 0.75rem; }

  /* Dimensions */
  .rcxbuggy-h-4 { height: 1rem; }
  .rcxbuggy-h-8 { height: 2rem; }
  .rcxbuggy-h-28 { height: 7rem; }
  .rcxbuggy-h-44 { height: 11rem; }
  .rcxbuggy-h-56 { height: 14rem; }
  .rcxbuggy-h-auto { height: auto; }

  .rcxbuggy-w-4 { width: 1rem; }
  .rcxbuggy-w-8 { width: 2rem; }
  .rcxbuggy-w-28 { width: 7rem; }
  .rcxbuggy-w-full { width: 100%; }

  .rcxbuggy-object-cover { object-fit: cover; }
  .rcxbuggy-ring-2 { box-shadow: 0 0 0 2px; }
  .rcxbuggy-ring-white { box-shadow: 0 0 0 2px #ffffff; }

  /* Star rating styles */
  .rcxbuggy-star-rating { 
    display: flex;
    gap: 0.125rem;
    align-items: center;
  }
  .rcxbuggy-star-rating img {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  /* Interactive */
  .rcxbuggy-cursor-pointer { cursor: pointer; }
  .rcxbuggy-transition { transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1); }

  .rcxbuggy-wrapper a {
    text-decoration: none;
    color: inherit;
    transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rcxbuggy-hover-opacity-90:hover { opacity: 0.9; }
  .rcxbuggy-hover-bg-blue-700:hover { background-color: #1d4ed8; }
  .rcxbuggy-hover-bg-black-90:hover { background-color: rgba(0, 0, 0, 0.9); }

  /* Details/Summary */
  .rcxbuggy-wrapper details summary::-webkit-details-marker { display: none; }

  .rcxbuggy-details-group summary .rcxbuggy-group-open-rotate-90 {
    transition: transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .rcxbuggy-details-group[open] summary .rcxbuggy-group-open-rotate-90 {
    transform: rotate(90deg);
  }
  .rcxbuggy-details-group[open] .rcxbuggy-open-shadow-sm {
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05); }

  /* Gradient */
  .rcxbuggy-bg-gradient-to-r {
    background-image: linear-gradient(to right, #2563eb, #3b82f6);
  }
  .rcxbuggy-white-90 { background-color:#F2F0EE; }

  .rcxbuggy-wrapper img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  .rcxbuggy-wrapper figure { margin: 0; }

  /* Button styles */
  .rcxbuggy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: #ffffff;
  }
  .rcxbuggy-btn.rcxbuggy-btn-white {
    color: #2563eb;
    background-color: #ffffff;
  }
  .rcxbuggy-btn.rcxbuggy-btn-white:hover { opacity: 0.9; }
  .rcxbuggy-btn.rcxbuggy-btn-blue {
    color: #ffffff;
    background-color: #2563eb;
  }
  .rcxbuggy-btn.rcxbuggy-btn-blue:hover { background-color: #1d4ed8; }
  .rcxbuggy-btn.rcxbuggy-btn-dark {
    color: #ffffff;
    background-color: #111827;  }
  .rcxbuggy-btn.rcxbuggy-btn-dark:hover { background-color: rgba(0, 0, 0, 0.9); }

  .rcxbuggy-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  /* Media Queries */
  @media (max-width: 639px) {
    .rcxbuggy-sm-px-6 { padding-left: 1rem; padding-right: 1rem; }
    .rcxbuggy-sm-p-6 { padding: 3rem; }
    .rcxbuggy-sm-pt-8 { padding-top: 2rem; }
    .rcxbuggy-sm-pb-8 { padding-bottom: 2rem; }
    .rcxbuggy-white-90 { background-color: #F3F1EF;}
    .rcxbuggy-mt-8 { margin-top: 2rem; }
    .rcxbuggy-mb-8 { margin-bottom: 2rem; margin-top: 1rem;}
    
    /* Typography Overrides */
    .rcxbuggy-h1-hero { font-size: 33px; line-height: 34px; }
    .rcxbuggy-h2-section { font-size: 28px; line-height: 36px; }
    .rcxbuggy-h3-heading { font-size: 24px; line-height: 32px; }
    .my-responsive-title { font-size: 30px; }

    .rcxbuggy-text-base { font-size: 13px; line-height: 20px; }
    .rcxbuggy-text-lg { font-size: 13px; line-height: 20px;}
    .rcxbuggy-text-sm { font-size: 14px; line-height: 20px; margin-bottom:3px; }
    .rcxbuggy-text-base2 { font-size: 18px; line-height: 20px; }
    .rcxbuggy-text-lg2 { font-size: 18px; line-height: 20px; }
  }

  @media (min-width: 640px) {
    .rcxbuggy-sm-px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .rcxbuggy-sm-p-6 { padding: 1.5rem; }
    .rcxbuggy-sm-flex-row { flex-direction: row; }
    .rcxbuggy-sm-text-lg { font-size: 18px; line-height: 28px; }
    .rcxbuggy-sm-text-4xl { font-size: 36px; line-height: 44px; }
    .rcxbuggy-sm-text-5xl { font-size: 48px; line-height: 52px; }
    .rcxbuggy-sm-grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 768px) {
    .rcxbuggy-md-grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 1024px) {
    .rcxbuggy-lg-px-8 { padding-left: 2rem; padding-right: 2rem; }
    .rcxbuggy-lg-grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .rcxbuggy-lg-grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .rcxbuggy-lg-grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .rcxbuggy-lg-p-8 { padding: 2rem; }
    .rcxbuggy-lg-h-12 { height: 3rem; } /* Adjusted from original to prevent parse error if variable wasn't used */
    .rcxbuggy-lg-w-12 { width: 3rem; }
    .rcxbuggy-lg-space-x-minus-4 > * { margin-left: -1rem; }
    .rcxbuggy-lg-space-x-minus-4 > *:first-child { margin-left: 0; }
  }

  .rcxbuggy-main { width: 100%; }
  .rcxbuggy-section { width: 100%; }
</style>

<div class="rcxbuggy-wrapper">
  <main class="rcxbuggy-main rcxbuggy-bg-white">
    
    {% for block in section.blocks %}
      {% case block.type %}
        
        {% when 'hero' %}
          {% style %}
            .rcx-block-{{ block.id }} {
              padding-left: {{ block.settings.padding_x }}px;
              padding-right: {{ block.settings.padding_x }}px;
              padding-top: {{ block.settings.padding_top }}px;
              padding-bottom: {{ block.settings.padding_bottom }}px;
              {% if block.settings.enable_max_width %}
                max-width: 90%;
              {% else %}
                max-width: 100%;
              {% endif %}
            }
            .rcx-block-{{ block.id }} .rcx-hero-title {
              font-size: {{ block.settings.heading_size }}px;
            }
            .rcx-block-{{ block.id }} .rcx-hero-subtitle {
              font-size: {{ block.settings.subheading_size }}px;
            }
            .rcx-block-{{ block.id }} .rcx-hero-trustpilot-img {
              height: {{ block.settings.trustpilot_stars_height }}px;
            }
            .rcx-block-{{ block.id }} .rcx-hero-stats {
              margin-top: {{ block.settings.stats_margin_top }}px;
              padding: {{ block.settings.stats_box_padding_desktop }}px;
            }
            .rcx-block-{{ block.id }} .rcx-hero-avatar {
              width: {{ block.settings.avatar_size }}px;
              height: {{ block.settings.avatar_size }}px;
            }

            @media (min-width: 1024px) {
               {% if block.settings.enable_max_width %}
               .rcx-block-{{ block.id }} { max-width: 82%; }
               {% endif %}
            }

            @media (max-width: 639px) {
              .rcx-block-{{ block.id }} {
                padding-left: {{ block.settings.padding_x_mobile }}px;
                padding-right: {{ block.settings.padding_x_mobile }}px;
                padding-top: {{ block.settings.padding_top_mobile }}px;
                padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
                max-width: {{ block.settings.mobile_max_width }}%;
              }
              .rcx-block-{{ block.id }} .rcx-hero-title {
                font-size: {{ block.settings.heading_size_mobile }}px;
              }
              .rcx-block-{{ block.id }} .rcx-hero-subtitle {
                font-size: {{ block.settings.subheading_size_mobile }}px;
              }
              .rcx-block-{{ block.id }} .rcx-hero-trustpilot-img {
                height: {{ block.settings.trustpilot_stars_height_mobile }}px;
              }
              .rcx-block-{{ block.id }} .rcx-hero-stats {
                margin-top: {{ block.settings.stats_margin_top_mobile }}px;
                padding: {{ block.settings.stats_box_padding_mobile }}px;
              }
              .rcx-block-{{ block.id }} .rcx-hero-avatar {
                width: {{ block.settings.avatar_size_mobile }}px;
                height: {{ block.settings.avatar_size_mobile }}px;
              }
            }
          {% endstyle %}
          <section class="rcx-block-{{ block.id }} rcxbuggy-section rcxbuggy-relative rcxbuggy-mx-auto" {{ block.shopify_attributes }}>
            <div class="rcxbuggy-mx-auto rcxbuggy-max-w-3xl {{ text_align_class }}">
              <h1 class="rcx-hero-title rcxbuggy-h1-hero rcxbuggy-text-gray-900" style="font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; text-transform: none; letter-spacing: normal; word-spacing: normal;">
                {{ block.settings.title_pre }} <span class="rcxbuggy-text-blue-600">{{ block.settings.title_highlight }}</span> {{ block.settings.title_post }}
              </h1>

              <p class="rcx-hero-subtitle rcxbuggy-mx-auto rcxbuggy-mt-4 rcxbuggy-max-w-2xl rcxbuggy-text-lg rcxbuggy-text-gray-600">
                {{ block.settings.subtitle }}
              </p>
            </div>

            <div class="rcxbuggy-mt-6 rcxbuggy-flex rcxbuggy-items-center {{ justify_class }} rcxbuggy-gap-3">
              {% if block.settings.trustpilot_image != blank %}
                <img src="{{ block.settings.trustpilot_image | img_url: 'master' }}" class="rcx-hero-trustpilot-img rcxbuggy-w-auto" alt="Trustpilot Rating">
              {% endif %}
              <span class="rcxbuggy-text-2xl rcxbuggy-font-bold rcxbuggy-text-gray-900" style="font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">{{ block.settings.trustpilot_score }}</span>
            </div>

            <div class="rcx-hero-stats rcxbuggy-rounded-2xl rcxbuggy-border rcxbuggy-border-gray-100 rcxbuggy-bg-gray-50">
              <div class="rcxbuggy-flex rcxbuggy-flex-col rcxbuggy-items-center rcxbuggy-justify-between rcxbuggy-gap-4 rcxbuggy-sm-flex-row">
                <p class="rcxbuggy-text-sm rcxbuggy-font-semibold rcxbuggy-text-gray-700">
                  <span class="rcxbuggy-text-blue-600">{{ block.settings.stat_number }}</span> {{ block.settings.stat_text }}
                  <span class="rcxbuggy-ml-1 rcxbuggy-inline-flex rcxbuggy-items-center rcxbuggy-rounded-full rcxbuggy-bg-green-100 rcxbuggy-px-2 rcxbuggy-py-0-5 rcxbuggy-text-green-800 rcxbuggy-text-xs rcxbuggy-font-semibold">{{ block.settings.stat_score }}</span>
                </p>
                <div class="rcxbuggy-flex rcxbuggy-space-x-minus-3 rcxbuggy-lg-space-x-minus-4">
                  {% for i in (1..6) %}
                    {% assign avatar_key = 'avatar_' | append: i %}
                    {% assign avatar_img = block.settings[avatar_key] %}
                    {% if avatar_img != blank %}
                      <img loading="lazy" src="{{ avatar_img | img_url: '96x96' }}" class="rcx-hero-avatar rcxbuggy-rounded-full rcxbuggy-ring-2 rcxbuggy-ring-white" alt="Client {{ i }}">
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            </div>
          </section>

        {% when 'featured_testimonials' %}
          {% style %}
            .rcx-block-{{ block.id }} {
              padding-left: {{ block.settings.padding_x }}px;
              padding-right: {{ block.settings.padding_x }}px;
              padding-top: {{ block.settings.padding_top }}px;
              padding-bottom: {{ block.settings.padding_bottom }}px;
              {% if block.settings.enable_max_width %}max-width: 90%;{% else %}max-width: 100%;{% endif %}
            }
            .rcx-block-{{ block.id }} .rcx-section-title {
              font-size: {{ block.settings.heading_size }}px;
            }
            .rcx-block-{{ block.id }} .rcx-section-subtitle {
              font-size: {{ block.settings.subheading_size }}px;
            }

            @media (min-width: 1024px) {
               {% if block.settings.enable_max_width %}.rcx-block-{{ block.id }} { max-width: 82%; }{% endif %}
            }

            @media (max-width: 639px) {
              .rcx-block-{{ block.id }} {
                padding-left: {{ block.settings.padding_x_mobile }}px;
                padding-right: {{ block.settings.padding_x_mobile }}px;
                padding-top: {{ block.settings.padding_top_mobile }}px;
                padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
                max-width: {{ block.settings.mobile_max_width }}%;
              }
              .rcx-block-{{ block.id }} .rcx-section-title {
                font-size: {{ block.settings.heading_size_mobile }}px;
              }
