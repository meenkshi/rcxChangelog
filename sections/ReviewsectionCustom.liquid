{% schema %}
{
  "name": "RCXBuggy Blocks Page",
  "settings": [
    {
      "type": "select",
      "id": "section_alignment",
      "label": "Section Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero Section",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title_pre",
          "label": "Title Prefix",
          "default": "Les voitures "
        },
        {
          "type": "text",
          "id": "title_highlight",
          "label": "Title Highlight",
          "default": "RCX Buggy"
        },
        {
          "type": "text",
          "id": "title_post",
          "label": "Title Suffix",
          "default": " font parler"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Heading Size",
          "min": 12,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 48
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Depuis 2019, des milliers de pilotes en Europe choisissent RCX Buggy pour la performance, la solidité et le fun."
        },
        {
          "type": "range",
          "id": "subheading_size",
          "label": "Subheading Size",
          "min": 12,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 18
        },
        {
          "type": "header",
          "content": "Trustpilot"
        },
        {
          "type": "image_picker",
          "id": "trustpilot_image",
          "label": "Trustpilot Stars Image"
        },
