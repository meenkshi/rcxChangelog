{% schema %}
{
  "name": "Top Announcement Bar",
  "settings": [
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#009C63"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Social Media (Desktop)"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "Show Social Icons",
      "default": true
    },
{
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram Link"
    },
    {
      "type": "image_picker",
      "id": "social_instagram_icon",
      "label": "Instagram Icon (Optional)"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok Link"
    },
    {
      "type": "image_picker",
      "id": "social_tiktok_icon",
      "label": "TikTok Icon (Optional)"
    },
    {
      "type": "header",
      "content": "Localization (Desktop)"
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "Show Country/Language Selectors",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "language_icon",
      "label": "Language Icon (Optional)"
    },
    {
      "type": "image_picker",
      "id": "currency_icon",
      "label": "Currency Icon (Optional)"
    },
    {
      "type": "image_picker",
      "id": "chevron_icon",
      "label": "Dropdown Chevron (Optional)"
    },
{
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 0.5,
      "max": 10,
      "step": 0.1,
      "unit": "s",
      "label": "Autoplay Speed",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "limit_visibility",
      "label": "Show on Home and Product pages only",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Message",
          "default": "Free shipping on all orders over £50"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Shipping Truck" },
            { "value": "star", "label": "Star (Yellow)" },
{ "value": "klarna", "label": "Klarna/Payment" }
          ],
          "default": "none"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Icon (Overrides selector)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Buy now, pay later with Klarna",
            "icon": "truck"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "4,8/5 · Customer service in English 🇬🇧",
            "icon": "star"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  #shopify-section-{{ section.id }} {
    --top-bar-bg: {{ section.settings.bg_color }};
    --top-bar-text: {{ section.settings.text_color }};
    --top-bar-height: 42px;
    position: relative;
    z-index: 50;
  }

.top-bar {
    background-color: var(--top-bar-bg);
    color: var(--top-bar-text);
    height: var(--top-bar-height);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 13px;
    line-height: 1.5;
    overflow: hidden;
  }

  .top-bar__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Socials (Left) */
  .top-bar__socials {
    display: none;
    gap: 16px;
    align-items: center;
    flex: 1;
  }

  .top-bar__social-link {
    color: currentColor;
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }

  .top-bar__social-link:hover {
    opacity: 0.8;
  }

.top-bar__social-link svg,
  .top-bar__social-link img {
    width: 18px;
    height: 18px;
    fill: currentColor;
    object-fit: contain;
    display: block;
  }

  /* Slider (Center) */
  .top-bar__slider {
    flex: 2;
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .top-bar__slide {
    position: absolute;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    opacity: 0;
    transform: translateY(100%);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.5s ease;
    will-change: transform, opacity;
    pointer-events: none;
  }

  .top-bar__slide.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

.top-bar__slide.is-leaving {
    opacity: 0;
    transform: translateY(-100%);
  }

  .top-bar__text {
    display: flex;
    align-items: center;
    gap: 4px;
    line-height: 1;
  }

.top-bar__icon svg,
  .top-bar__icon img {
    width: 18px;
    height: 18px;
    fill: currentColor;
    display: block;
    object-fit: contain;
  }

  .top-bar__icon--star svg {
    fill: #FFC107; /* Golden yellow for star */
    filter: drop-shadow(0px 1px 2px rgba(0,0,0,0.1));
  }

  /* Localization (Right) */
  .top-bar__localization {
    display: none;
    flex: 1;
    justify-content: flex-end;
    gap: 20px;
  }

  .top-bar__selector {
    background: none;
    border: none;
    color: currentColor;
    font-size: 13px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0;
    font-family: inherit;
  }

.top-bar__selector svg,
  .top-bar__selector img {
    width: 16px;
    height: 16px;
    fill: currentColor;
    object-fit: contain;
    display: block;
  }

  .top-bar__chevron {
    width: 10px !important;
    height: 10px !important;
    opacity: 0.8;
  }

  /* Mobile / Desktop Queries */
  @media screen and (min-width: 990px) {
    .top-bar__socials {
      display: flex;
    }
    .top-bar__localization {
      display: flex;
    }
  }
  
@media screen and (max-width: 989px) {
    .top-bar__container {
      justify-content: center;
      padding: 0 10px;
    }
.top-bar__text {
      font-size: 13px;
      font-weight: 400;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: flex;
      align-items: center;
      gap: 4px;
      line-height: 1;
      letter-spacing: normal;
      word-spacing: normal;
    }
  }
</style>

{%- if section.settings.limit_visibility == false or template.name == 'index' or template.name == 'product' -%}
<div class="top-bar" role="region" aria-label="Announcement Bar">
  <div class="top-bar__container">
    
<!-- Left: Socials -->
    {%- if section.settings.show_socials -%}
      <div class="top-bar__socials">
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="top-bar__social-link" aria-label="Instagram">
            {%- if section.settings.social_instagram_icon != blank -%}
              {{ section.settings.social_instagram_icon | image_url: width: 36 | image_tag: loading: 'lazy', width: 18, height: 18 }}
            {%- else -%}
              {% render 'icon-set-topbar', icon: 'instagram' %}
            {%- endif -%}
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="top-bar__social-link" aria-label="TikTok">
            {%- if section.settings.social_tiktok_icon != blank -%}
              {{ section.settings.social_tiktok_icon | image_url: width: 36 | image_tag: loading: 'lazy', width: 18, height: 18 }}
            {%- else -%}
              {% render 'icon-set-topbar', icon: 'tiktok' %}
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

<!-- Center: Slider -->
    <div class="top-bar__slider" id="TopBarSlider-{{ section.id }}" data-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}">
      {%- for block in section.blocks -%}
        <div class="top-bar__slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
{%- if block.settings.custom_icon != blank -%}<span class="top-bar__icon">{{ block.settings.custom_icon | image_url: width: 36 | image_tag: loading: 'lazy', width: 18, height: 18 }}</span>{%- elsif block.settings.icon != 'none' -%}<span class="top-bar__icon top-bar__icon--{{ block.settings.icon }}">{% render 'icon-set-topbar', icon: block.settings.icon %}</span>{%- endif -%}<span class="top-bar__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
    </div>

<!-- Right: Localization -->
    {%- if section.settings.show_localization -%}
      <div class="top-bar__localization">
        {%- form 'localization', id: 'TopBarLocalization' -%}
          <div style="display:flex; gap: 20px;">
            <button type="button" class="top-bar__selector">
              {%- if section.settings.language_icon != blank -%}
                {{ section.settings.language_icon | image_url: width: 32 | image_tag: loading: 'lazy', width: 16, height: 16 }}
              {%- else -%}
                {% render 'icon-set-topbar', icon: 'globe' %}
              {%- endif -%}
              <span>{{ localization.language.endonym_name | capitalize | default: 'English' }}</span>
              {%- if section.settings.chevron_icon != blank -%}
                {{ section.settings.chevron_icon | image_url: width: 20 | image_tag: loading: 'lazy', width: 10, height: 10, class: 'top-bar__chevron' }}
              {%- else -%}
                {% render 'icon-set-topbar', icon: 'chevron' %}
              {%- endif -%}
            </button>
            
            <button type="button" class="top-bar__selector">
              {%- if section.settings.currency_icon != blank -%}
                {{ section.settings.currency_icon | image_url: width: 32 | image_tag: loading: 'lazy', width: 16, height: 16 }}
              {%- else -%}
                {% render 'icon-set-topbar', icon: 'coins' %}
              {%- endif -%}
              <span>{{ localization.country.name }} ({{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }})</span>
              {%- if section.settings.chevron_icon != blank -%}
                {{ section.settings.chevron_icon | image_url: width: 20 | image_tag: loading: 'lazy', width: 10, height: 10, class: 'top-bar__chevron' }}
              {%- else -%}
                {% render 'icon-set-topbar', icon: 'chevron' %}
              {%- endif -%}
            </button>
          </div>
        {%- endform -%}
</div>
    {%- endif -%}

  </div>
</div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('TopBarSlider-{{ section.id }}');
    if (!slider) return;

    const slides = slider.querySelectorAll('.top-bar__slide');
    if (slides.length < 2) return;

    const intervalTime = parseInt(slider.dataset.autoplay) || 4000;
    let currentIndex = 0;

    setInterval(() => {
      const currentSlide = slides[currentIndex];
      const nextIndex = (currentIndex + 1) % slides.length;
      const nextSlide = slides[nextIndex];

      // Exit animation for current
      currentSlide.classList.remove('is-active');
      currentSlide.classList.add('is-leaving');

      // Enter animation for next
      nextSlide.classList.remove('is-leaving');
      nextSlide.classList.add('is-active');

      // Cleanup leaving class after transition
      setTimeout(() => {
        currentSlide.classList.remove('is-leaving');
      }, 500); 

      currentIndex = nextIndex;
    }, intervalTime);
  });
</script>