        		<div class="product-single__description rte product4">
                  {% assign H1F = '<h1' %}{% assign H1L = '</h1>' %}{% assign DIVF = '<div' %}{% assign DIVL = '/div>' %}
                  {{ source_content | split: H1F | first }}        
                  <ul class="accordionX">         
                    {% assign splitH1F = source_content | split:H1F %}
                    {% assign tabCount = splitH1F.size | minus:1 %}
                    {% for i in (1..tabCount) %}
                      {% assign content = source_content | split: H1L %}
                      {% assign content_title = content[forloop.index0] | strip | strip_newlines | split: H1F | last %}
                      {% unless forloop.last and content_title contains 'FIN' or content_title contains 'Fin' or content_title contains 'fin' %}
                        {% if content_title contains 'style="' or content_title contains 'class="' %}{% capture attributes %}{{ content_title | split: '>' | first }}{% endcapture %}{% endif %}
                        {% if content_title contains '<img' %}{% capture img_title %}{{ content_title | split: '<img' | last | split: '>' | first | prepend: '<img' | append: '>' }}{% endcapture %}{% endif %}
                    	<li>                                    
                          <a id="tab{{ forloop.index }}">
                            <span {% if forloop.first %}class="active"{% endif %}{{ attributes }}>{{ img_title }}{{ content_title | remove: attributes | strip_html | remove: '>' }}</span>
                          </a>                                  
                          <div class="in-accordion" {% if forloop.first %}style="display:block"{% endif %}>                                  
                            {% capture content_description %}{{ content[i] | split: H1F | first }}{% endcapture %}
                            {% assign splitDIVF = content_description | split: DIVF %}{% assign splitDIVL = content_description | split: DIVL %}
                            {% assign openDivs = splitDIVL.size | minus: splitDIVF.size %}{% assign closeDivs = splitDIVF.size | minus: splitDIVL.size %}
                            {% if openDivs > 0 %}{% for i in (1..openDivs) %}<div>{% endfor %}{% endif %}               
                            {{ content_description | replace: 'src=', 'class="lazyload" data-src=' }}
                            {% if closeDivs > 0 %}{% for i in (1..closeDivs) %}</div>{% endfor %}{% endif %}
                          </div>
                        </li> 
                      {% else %}
                      	{% capture content_end %}{{ content[i] }}{% endcapture %}
                      {% endunless %}
                      {% assign img_title = nil %}{% assign attributes = nil %}{% assign closeDivs = nil %}{% assign openDivs = nil %}
                    {% endfor %}
                  </ul>
                  {{ content_end }}
        		</div>
            	{% else %}
                  <div class="product-single__description rte product5">
                    {{ source_content }}
                  </div>
            	{% endif %}
				{% assign content_end = nil %}          		

