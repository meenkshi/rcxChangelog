    <script>

function view3D() {  
  window.CI360.init();
  document.getElementById("viewthumb").style.display="none";
  document.getElementById("viewimg").style.display="none";
  document.getElementById("view360").style.display = "block";
  var btnimg = document.getElementById("selectImg")
  var btn3D = document.getElementById("select3D")
  if (btnimg.classList.contains("btnchecked")) {
        btnimg.classList.remove("btnchecked");
        btn3D.classList.add("btnchecked");
    }
}

function viewImg() {  
  document.getElementById("viewthumb").style.display="block";
  document.getElementById("viewimg").style.display="block";
  document.getElementById("view360").style.display = "none";
  var btnimg = document.getElementById("selectImg")
  var btn3D = document.getElementById("select3D")
  if (btn3D.classList.contains("btnchecked")) {
        btn3D.classList.remove("btnchecked");
        btnimg.classList.add("btnchecked");
    }
}

        
      </script>

