                	  {% assign original_compared_price = true %}
                      <del class="cartItems__prices-compare" id="{{item.variant.id}}">{% if price_format_new %}{{ item.variant.compare_at_price | times: item.quantity | money_without_currency | replace_first: ',', moneyFormat | remove: '€ ' | remove: '00' | strip | replace_first: '.', moneyFormat | remove: '€ ' | remove: '00' | strip }}{% else %}{{ item.variant.compare_at_price | times: item.quantity | money_without_trailing_zeros }}{% endif %}</del>
                      {% endif %}
                	{% endif %}
{% if item.original_line_price != item.line_price and original_compared_price == nil %}
                <del><small class="cartItems__prices-original" id="{{item.variant.id}}">{% if price_format_new %}{{ item.original_line_price |  money_without_currency | replace_first: ',', moneyFormat | remove: '00' | strip | replace_first: '.', moneyFormat | remove: '€ ' | remove: '00' | strip }}{% else %}{{ item.original_line_price | money_without_trailing_zeros }}{% endif %}</small></del>
                {% endif %}
<div class="cartItems__prices-total" id="{{item.variant.id}}">
