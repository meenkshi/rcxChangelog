<script>

  
    function observeStickyBtn() {
      /* improve sticky effect on scroll */
      if (window.matchMedia("(max-width: 1100px)").matches) {
        var buttonVisible = false;
        setTimeout(function() {
          //place observer position
          var rect = document.querySelector('.pageWidth').getBoundingClientRect();
          document.querySelector('.scroll__observer').style.top = -(rect.top - 2) + 'px'
        },1000)
        let observer = new IntersectionObserver(entries => {
          if(entries[0].target == document.querySelector('.sticky_sentinel--bottom')) {
            if (entries[0].isIntersecting ) {
              console.log('bottom < 0', entries[0].boundingClientRect.y)
              document.querySelector('.btnCart__sticky').classList.remove('btnCart__sticky--shadow');
              buttonVisible = true;
            } else {
              console.log('bottom > 0 page load', entries[0].boundingClientRect.y)
              document.querySelector('.btnCart__sticky').classList.add('btnCart__sticky--shadow');

            }
          } else {
            if (entries[0].isIntersecting ) {
              console.log('top < 0')
              if(!buttonVisible) {
                document.querySelector('.btnCart__sticky').classList.add('btnCart__sticky--shadow');
              }
            }
          }
        });
        observer.observe(document.querySelector(".sticky_sentinel--bottom"));
        observer.observe(document.querySelector(".scroll__observer"));
      }
    } observeStickyBtn();

  
  //prevent too many click per ms on quantity buttons
  var last, diff;
  function monitorClicks(event) {
    if (last){diff = event.timeStamp - last;if (diff >= 500){last++;} else {console.warn('Too many simultaneous requests');return false}}last = event.timeStamp;return true
  }
    
  {% if section.blocks[timer].settings.cart_show_timer %}
      //this function fire when cart is rendered for the first time. There is a cookie deposited for 1 day
        function cdTimer() {
          var totalTime = {{ section.blocks[timer].settings.cart_timer_time }}*60*1000; // Amout of time (sec)  
          var timerExist = document.querySelector('#cdTimerCart');
          if(!document.cookie.match(/^(.*;)?\s*cdTime\s*=\s*[^;]+(.*)?$/) && timerExist != null) {

            // First time on page                
            var firstTime = new Date(); 
            // Set first time cookie
            function CookieFirstTime(cname, cvalue, exdays) {          
              var d = new Date();
              d.setTime(d.getTime() + (exdays*60*1000));
              var expires = "expires="+ d.toUTCString();
              document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
            }        
            CookieFirstTime('firstTime', firstTime, {{ section.blocks[timer].settings.cart_timer_renew }})             

            //Set total time given to countdown timer
            function CookieTotalTime(cname, cvalue, exdays) {
              var d = new Date();
              d.setTime(d.getTime() + (exdays*60*1000));
              var expires = "expires="+ d.toUTCString();
              document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
            }        
            CookieTotalTime('cdTime', totalTime, {{ section.blocks[timer].settings.cart_timer_renew }}); 

            //initial total deadline
            var deadline = new Date(Date.parse(new Date()) + totalTime);
            //initialiez the timer     	
            initializeClock('cdTimerCart', deadline);

          } else if (timerExist != null) {

            //get firsttime cookie value
            var firstTimeValue = Date.parse(document.cookie.replace(/(?:(?:^|.*;\s*)firstTime\s*\=\s*([^;]*).*$)|^.*$/, "$1"));        
            var currentTime = Date.parse(new Date());
            var usedTime = (currentTime - firstTimeValue); // Calculate and convert into seconds       
            //new deadline after time has passed
            var runTimer = new Date(Date.parse(new Date()) + (totalTime - usedTime));        
            //initialie the timer and show it  
            initializeClock('cdTimerCart', runTimer);
          }


          //setup time formats
          function getTimeRemaining(endtime) {
            var t = Date.parse(endtime) - Date.parse(new Date());
            var seconds = Math.floor((t / 1000) % 60);
            var minutes = Math.floor((t / 1000 / 60) % 60);
            var hours = Math.floor((t / (1000 * 60 * 60)) % 24);
            var days = Math.floor(t / (1000 * 60 * 60 * 24));
            return {
              'total': t,
              'days': days,
              'hours': hours,
              'minutes': minutes,
              'seconds': seconds
            };
          }

          //insert timer value in html
          function initializeClock(id, endtime) {
            var clock = document.getElementById(id);
            //var daysSpan = clock.querySelector('#days');
            //var hoursSpan = clock.querySelector('#hours');
            var minutesSpan = clock.querySelector('#cart_minutes');
            var secondsSpan = clock.querySelector('#cart_seconds');

            function updateClock() {
              var t = getTimeRemaining(endtime);
              //daysSpan.innerHTML = ('0' + t.days).slice(-2);
              //hoursSpan.innerHTML = ('0' + t.hours).slice(-2);
              minutesSpan.innerHTML = ('0' + t.minutes).slice(-2);
              secondsSpan.innerHTML = ('0' + t.seconds).slice(-2);

              //reset timer when days > 0
              if (t.total <= 0 || isNaN(t.total)) {
                clearInterval(timeinterval);  
                timerExist.remove();
              }
            }
            updateClock();
            var timeinterval = setInterval(updateClock, 1000);
          }
        } cdTimer() 
  {% endif %}
    
  //cart json data  
  let cart = {{ cart | json }};
  
      // update quantities
      for(var key in cart.items){ 
        //const i = Object.keys(cart.items).indexOf(key)
        let variantID = cart.items[key].variant_id;
        let variantKey = cart.items[key].key;
        let handle = cart.items[key].handle;       
        let inputEl = document.querySelector(`[name="updates[${variantKey}]"]`);
        let value = parseInt(inputEl.value, 10)        
        inputEl.previousElementSibling.addEventListener('click', function(event) {
          let validateClick = monitorClicks(event);
          if (!validateClick) return;
          value = isNaN(value) ? 0 : value;
          value--;
          inputEl.value = value;
          {% if settings.activate_free_product or discount_available %}     
          	  {% assign updateCart = true %}
          	  {% assign break_loop = false %}
              {% for item in cart.items %}  
                 {% for collection in item.product.collections %}
                      {% if collection.handle == settings.collection_free_product or item.variant.id == all_products[settings.free_product].variants.first.id or discount_available %}  
                          var cart = new XMLHttpRequest();
                          var url = '/cart/change.js';
                          var params = 'quantity=' + value + '&id=' + variantKey;
                          cart.open('POST', url, true);
                          cart.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');
                          cart.onreadystatechange = function() {if(cart.readyState == 4 && cart.status == 200) {window.location.reload(true)}}
                          cart.send(params);
                        {% assign updateCart = false %} 
                        {% break %}
          				{% assign break_loop = true %}                    
                      {% endif %}                     
                  {% endfor %}
          		  {% if break_loop %}{% break %}{% endif %}
                {% endfor %}
                {% if updateCart == true %}
          			updateCart(variantKey, variantID, value, handle)
                {% endif %}
          {% else %}   
              updateCart(variantKey, variantID, value, handle)
          {% endif %}
        })
        inputEl.nextElementSibling.addEventListener('click', function(event) {
          let validateClick = monitorClicks(event);
          if (!validateClick) return;
          value = isNaN(value) ? 0 : value;
          value++;
          inputEl.value = value;
          {% if settings.activate_free_product or discount_available %}     
          	  {% assign updateCart = true %}
          	  {% assign break_loop = false %}
              {% for item in cart.items %}  
                 {% for collection in item.product.collections %}
                      {% if collection.handle == settings.collection_free_product or item.variant.id == all_products[settings.free_product].variants.first.id or discount_available %}  
                          var cart = new XMLHttpRequest();
                          var url = '/cart/add.js';
                          var params = 'quantity=1&id=' + variantID;
                          cart.open('POST', url, true);
                          cart.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');
                          cart.onreadystatechange = function() {if(cart.readyState == 4 && cart.status == 200) {window.location.reload(true)}}
                          cart.send(params);
                        {% assign updateCart = false %} 
                        {% break %}
          				{% assign break_loop = true %}                    
                      {% endif %}                     
                  {% endfor %}
          		  {% if break_loop %}{% break %}{% endif %}
                {% endfor %}
                {% if updateCart == true %}
          			updateCart(variantKey, variantID, value, handle)
                {% endif %}
          {% else %}   
              updateCart(variantKey, variantID, value, handle)
          {% endif %}
        })
      }

  // POST item and call render cart function
  function updateCart(variantKey, variantID, quantity, handle) {     
    var cart = new XMLHttpRequest();
    var url = '/cart/change.js';
    var params = 'quantity=' + quantity + '&id=' + variantID;
    cart.open('POST', url, true);
    cart.setRequestHeader('Content-type', 'application/x-www-form-urlencoded');
    cart.onreadystatechange = function() {
      if(cart.readyState == 4 && cart.status == 200) {
        let myCart = JSON.parse(cart.responseText)
        if (myCart.total_discount > 0) {window.location.reload(true)}else{renderCart(myCart, variantID, handle, quantity)}
      }
    }
    cart.send(params);
  }

  //split decimals for layout
  function priceDisplay(price) {
    const [priceAmount, priceCents] =  (price / 100).toFixed(2).toString().replace(/\.00$/,'.').split('.');
    return {priceAmount, priceCents}
  }  

  //cart rendering
  function renderCart(cart, updatedID, handle, quantity) {
    {% if settings.activate_free_product %}
    {% for item in cart.items %}    
    {% if item.variant.id == all_products[settings.free_product].variants.first.id %}
    window.location.reload(true);
    return
    {% endif %}
    {% endfor %}
    {% endif %}
    var custom_compare_at_price_sum = 0;  
    for(var key in cart.items){ 
      let item = cart.items[key];
      let variantID = item.variant_id;
      if (variantID == updatedID) {
        let { priceAmount, priceCents } = priceDisplay(item.original_line_price)
        let { priceAmount: totalPriceAmount, priceCents: totalPriceCents} = priceDisplay(cart.original_total_price)    
        for (let item of cart.items){
          var product = new XMLHttpRequest();
          var url = '/products/' + item.handle + '.js';   
          product.open('GET', url, false);
          product.setRequestHeader('Content-type', 'application/json');
product.onreadystatechange = function() {
            if(this.readyState == 4 && this.status == 200) {
              //update original price
              if (cart.items[key].price === 0) {
                const freeText = document.querySelector(`.js-free-text-template`).textContent;
                document.querySelector(`.cartItems__prices-total[id="${updatedID}"]`).innerHTML = `<span style="color: {{ section.settings.free_product_text_color }};">${freeText}</span>`;
              } else {
                document.querySelector(`.cartItems__prices-total[id="${updatedID}"]`).innerHTML = `{% if price_format_new %}{% if money_symbol contains '£' or money_symbol contains '$' %}{{ money_symbol }}{% endif %}${priceAmount}<span class="cents">{% if money_symbol contains '€' %}{{ money_symbol }}{% endif %}.${priceCents}</span>{% else %}${theme.Currency.formatMoney(item.original_line_price, theme.moneyFormat)}{% endif %}`;
              }
              document.querySelector('.summary__price').innerHTML = `{% if price_format_new %}{% if money_symbol contains '£' or money_symbol contains '$' %}{{ money_symbol }}{% endif %}${totalPriceAmount}<span class="cents">{% if money_symbol contains '€' %}{{ money_symbol }}{% endif %}.${totalPriceCents}</span>{% else %}${theme.Currency.formatMoney(cart.original_total_price, theme.moneyFormat)}{% endif %}`;
             //update compare at price
              var myProduct = JSON.parse(this.responseText) 
              for (let variant of myProduct.variants){
                if (variant.id == item.variant_id){
                  if (variant.compare_at_price) {               
                    let compare_at_price_total = variant.compare_at_price*item.quantity;  
                    let { priceAmount, priceCents} = priceDisplay(compare_at_price_total);
                    document.querySelector(`.cartItems__prices-compare[id="${variant.id}"]`).innerHTML = `{% if price_format_new %}${priceAmount}<span class="cents">{{ money_symbol }}${priceCents}</span>{% else %}${theme.Currency.formatMoney(compare_at_price_total, theme.moneyFormat)}{% endif %}`;            
                    custom_compare_at_price_sum += compare_at_price_total 
                  } else {
                    let price_total = variant.price*item.quantity
                    custom_compare_at_price_sum += price_total 
                  }                  
                  break;
                }
              }              
            }
          }
          product.send();
        }     
      }
    } 
    //refresh page if element is removed from cart
    if (quantity == 0) window.location.reload(true)   
    if (custom_compare_at_price_sum - cart.total_price > 0){
      document.querySelector(".summary__savings-price").innerText = Math.round((custom_compare_at_price_sum - cart.total_price) / 100)
    } else if (document.querySelector('.summary__savings'))  {
      this.remove();    
    }
  }
  
  //submit button + loader
  document.querySelector('.btnCart').addEventListener('click', function(e) {
    e.preventDefault();
    this.querySelector('svg').classList.add('btn__svg--loading');
    this.classList.add('btnCart--loading');
    let discount = document.querySelector('.checkoutcode')
    var checkoutURL = '{{ routes.cart_url | append: '/checkout' }}'
    if(discount) { checkoutURL = '{{ routes.cart_url | append: '/checkout' }}?discount=' + discount.value;}
    window.location.href = checkoutURL
  })
  
</script>

