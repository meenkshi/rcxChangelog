                  {% else %}
                    {% if price_format_new %}{{ item.line_price | money_without_currency | replace_first: ',', moneyFormat | remove: '€ ' | remove: '00' | strip | replace_first: '.', moneyFormat | remove: '€ ' | remove: '00' | strip }}{% else %}{{ item.line_price | money_without_trailing_zeros }}{% endif %}
