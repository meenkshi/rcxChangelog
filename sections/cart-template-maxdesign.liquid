                <input name="updates[{{item.key}}]" id="Updates_{{ item.key }}" class="quantity-selector" value="{{ item.quantity }}" min="0" data-line="{{ forloop.index }}" aria-label="{{ 'cart.label.quantity' | t }}"{% if item.price == 0 %} readonly{% endif %}>
                <button type="button"{% if item.price == 0 %} disabled style="opacity: 0.3; cursor: not-allowed;"{% endif %}>+</button>
              </div>
            </div>
            <div class="cartItems__prices-container">
              <div class="cartItems__prices {% if price_format_new == false and item.variant.price >= 10000 or item.variant.compare_at_price >= 10000 or smaller_font %}{% assign smaller_font = true %}cartItems__prices--smaller{% endif %}">
        			{% if section.blocks[savings].settings.compare_price_enable %}              
