      {% if section.settings.upsell_enable %}



  {% assign btn_brightness = section.settings.upsell_atcbg | color_brightness | plus:0 | round %}
  {% if btn_brightness > 40 and btn_brightness != 255 %}{% assign btn_color_hover = section.settings.upsell_atcbg | color_darken: 10 %}{% else %}{% assign btn_color_hover = section.settings.upsell_atcbg | color_lighten: 15 %}{% endif %}
        
  {% comment %}
  Make a loop that goes through all different items in the cart. 
  Forloop last is necessary to get only the final number and times:1 to convert string to a number
  This will be used later to show or hide the upsell.
  {% endcomment %}
  {% assign number_lineitems = 0 %}
  {% for item in cart.items %}
    {% if item.price > 0 %}
      {% assign number_lineitems = number_lineitems | plus: 1 %}
    {% endif %}
  {% endfor %}


  {% comment %}
  Capture the max items before the upsell is hidden, and multiply by one to convert from string to integer.
  This will be used later to show or hide the upsell.
  {% endcomment %}
  {% capture upsell_cap %}{{ section.settings.upsell_cap }}{% endcapture %}
  {% assign upsell_cap = upsell_cap | times:1 %}


  {% comment %}
  Make an array of all product ID in the cart. This will be used to check if the upsell we want to add is not already in the cart
  {% endcomment %}
  {% capture arr %}{% for item in cart.items %}{% if item.price > 0 %}{{-item.product.id-}},{% endif %}{% endfor %}{% endcapture %}
  {% assign array1 = arr | split: ',' %}


{% comment %}
  Go through the cart items and break the loop once an item meet conditions for upsell. Assign break_loop is to break the parent loop.
  The loop is set to not break when the upsell found is already in the cart, so that we check next line_item for upsell
  {% endcomment %}
{% assign any_upsell_in_cart = false %}
{% for block in section.blocks %}
  {% if block.type contains 'upsell' %}
    {% assign my_handle = block.settings.product_upsell %}
    {% assign upsell_id = all_products[my_handle].id | times:1 %}
    {% for myitem in array1 %}
      {% assign cartItem_id = myitem | times: 1 %}
      {% if cartItem_id != 0 and cartItem_id == upsell_id %}
        {% assign any_upsell_in_cart = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% if any_upsell_in_cart %}{% break %}{% endif %}
  {% endif %}
{% endfor %}

{% assign break_loop = false %}
{% unless any_upsell_in_cart %}
{% for item in cart.items %}
  {% if item.price == 0 %}{% continue %}{% endif %}
  {% capture collection_handle %}{% for collection in item.product.collections %}{{ collection.handle }}{% endfor %}{% endcapture %}
  {% for block in section.blocks %}
    {% if block.type contains 'upsell' %}
      {% if block.type == 'upsell1' %}
        {% if block.settings.trigger_product_id != blank %}
          {% assign upsell_ref = block.settings.trigger_product_id | times:1 %}
        {% elsif block.settings.upsell_reference == blank %}
          {% assign myref = block.settings.product_ref %}{% assign upsell_ref = all_products[myref].id %}
        {% else %}
          {% assign upsell_ref = block.settings.upsell_reference | times:1 %}
        {% endif %}
      {% else %}
        {% if block.settings.trigger_product_id != blank %}
          {% assign upsell_ref = block.settings.trigger_product_id %}
        {% else %}
          {% assign upsell_ref = block.settings.upsell_reference %}
        {% endif %}
      {% endif %}

{% if upsell_ref != blank and upsell_ref != 0 %}
        {% if item.variant.id == upsell_ref or item.product.id == upsell_ref or collection_handle contains upsell_ref %}
          {% assign my_handle = block.settings.product_upsell %}
          {% assign upsell_id = all_products[my_handle].id | times:1 %}
          {% assign already_in_cart = false %}
          {% for myitem in array1 %}
            {% assign cartItem_id = myitem | times: 1 %}
            {% if cartItem_id == upsell_id %}{% assign already_in_cart = true %}{% break %}{% endif %}
          {% endfor %}
  
          {% if already_in_cart == false %}
            {% assign variant_id = item.id | append: '' %}
            {% assign product_id = item.product.id | append: '' %}
            {% assign eligible_upsell = upsell_id | append: '-' | append: forloop.index %}
            {% assign break_loop = true %}
            {% break %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if break_loop %}{% break %}{% endif %}
{% endfor %}
{% endunless %}


