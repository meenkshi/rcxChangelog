{% for block in section.blocks %}
{% if block.type == 'bg' %}
{% assign bg = forloop.index0 | plus: 0 %}
{% elsif block.type == 'badges' %}
{% assign badges = forloop.index0 | plus: 0 %}
{% elsif block.type == 'savings' %}
{% assign savings = forloop.index0 | plus: 0 %}
{% elsif block.type == 'timer' %}
{% assign timer = forloop.index0 | plus: 0 %}
{% elsif block.type == 'customtext' %}
{% assign customtext = forloop.index0 | plus: 0 %}
{% elsif block.type == 'stepper' %}
{% assign stepper = forloop.index0 | plus: 0 %}
{% elsif block.type == 'announce' %}
{% assign announce = forloop.index0 | plus: 0 %}
{% elsif block.type == 'customcss' %}
{% assign customcss = forloop.index0 | plus: 0 %}
{% endif %}
{% endfor %}

{% if section.settings.price_format == 'original'%}{% assign price_format_new = false %}{% else %}{% assign price_format_new = true %}{% endif %}
{% capture money_symbol %}{{ 0 | money | remove: '0' | remove: '.' | remove: ',' | strip_html | strip }}{% endcapture %}
{% capture moneyFormat %}<span class="cents">{{ money_symbol }}{% endcapture %}
{% assign font_size_desktop = section.settings.font_size_desktop | divided_by: 100.0 | plus: 1 %}
{% assign font_size_mobile = section.settings.font_size_mobile | divided_by: 100.0 | plus: 1 %}
{% assign btn_brightness = section.settings.button_bg_color | color_brightness | plus:0 | round %}
{% if btn_brightness > 40 %}{% assign btn_color_hover = section.settings.button_bg_color | color_darken: 10 %}{% else %}{% assign btn_color_hover = section.settings.button_bg_color | color_lighten: 15 %}{% endif %}
{% capture wrapper_opacity %}{{ section.blocks[bg].settings.bg_secondary_opacity | divided_by: 100.0 }}{% endcapture %}
{% assign wrapper_opacity = wrapper_opacity | plus: 0 %}

{% case localization.language.iso_code %}
  {% when 'fr' %}
    {% assign free_text_auto = 'Gratuit' %}
  {% when 'nl', 'sv', 'es', 'de' %}
    {% assign free_text_auto = 'Gratis' %}
  {% else %}
    {% assign free_text_auto = 'Free' %}
{% endcase %}

<style>
  /* RESETS, ADMIN & UTILITIES */
  body .main-content.main-content, .mono-produit-true .main-content{padding:0!important;margin:0;max-width:none}
  p {font-size:1em;margin:0}
  .page-container {overflow:visible}
  iframe {display:none}
  #main.container{all:unset;-webkit-text-fill-color:initial}
  #shopify-section-{{ section.id }} {position:relative;z-index:0}
  #shopify-section-{{ section.id }} a{text-decoration:none;}  
  #shopify-section-{{ section.id }} {font-size:{{ font_size_mobile }}em;}
  #shopify-section-{{ section.id }} .additional-checkout-buttons iframe {border-radius:100px}
  #shopify-section-{{ section.id }} .additional-checkout-buttons {margin:0!important}
  #shopify-section-{{ section.id }} .additional-checkout-buttons .dynamic-checkout__content {min-height:62px}
  .md_desktop-hide {display:inherit}
  .md_mobile-hide {display:none}
  .md_all-hide {display:none!important}

  {% if section.blocks[announce].settings.cart_message_enable %}
  /* ANNOUNCE */ 
  .cart-message__wrapper {width:auto;display:block;background-color:{{ section.blocks[announce].settings.cart_message_bgcolor }};padding:10px 20px}
  .cart-message__text {text-align:left;}
  .cart-message__text p { color:{{ section.blocks[announce].settings.cart_message_color }};margin:0}
  {% endif %}
  
  {% if section.blocks[stepper].settings.stepper_mobile_enable or section.blocks[stepper].settings.stepper_desktop_enable %}
  /* STEPER */
  .checkoutsteps{font-size:0.9em;padding:0;position:relative;display:-webkit-box;display:-ms-flexbox;display:flex;display: -webkit-flex;width:100%;max-width:1200px;margin-bottom:20px;padding-top:15px;-webkit-box-sizing:border-box;box-sizing:border-box;}
  .checkoutsteps li{margin:0;position:relative;display:-webkit-box;display:-ms-flexbox;display:flex;display: -webkit-flex;-webkit-box-pack:center;-ms-flex-pack:center;justify-content:center;-webkit-box-flex:1;-ms-flex:1;flex:1;width:33%;-ms-flex-preferred-size:33%;flex-basis:33%;-webkit-box-flex:0;-ms-flex:0 0 33%;flex:0 0 33%;color:{{ section.blocks[stepper].settings.stepper_secondary_color }};font-weight:600;text-align:center;list-style-type:none;}
  .checkoutsteps span{position:relative;z-index:3;display:inline-block;padding:0 0 30px;text-decoration:none;color:{{ section.blocks[stepper].settings.stepper_main_color }};font-weight:600}
  .checkoutsteps li:after{box-sizing:border-box;content:'';position:absolute;left:50%;z-index:2;-webkit-transform:translate(-50%, 0);transform:translate(-50%, 0);display:block;background:#fff;border-radius:100%;bottom:3px;width:18px;height:18px;border:4px solid {{ section.blocks[stepper].settings.stepper_secondary_color }};}
  .checkoutsteps:after{content:'';position:absolute;bottom:11px;left:16.5%;display:block;width:66%;height:2px;background:{{ section.blocks[stepper].settings.stepper_secondary_color }};}
  .checkoutsteps li.current:after{border-color: {{ section.blocks[stepper].settings.stepper_main_color }};}
  {% endif %}

  /* MAIN WRAPPER */
  .pageWidth{*zoom:1;max-width:1280px;padding:0px;margin:0}
  .pageWidth:after{content:'';display:table;clear:both;}
  form[name="cartForm"] {margin:0;position:relative;}
  form[name="cartForm"]::after{content: " ";display: block;clear: both;}

  /* TABLE LEFT */
  /* & container */
  .cartItems__wrapper {display:block;width:100%;padding:0 20px;background-color:{{ section.blocks[bg].settings.bg_secondary_color | color_modify: 'alpha', wrapper_opacity }};}
  .cartItems__container {border-top: 1px solid {{ section.blocks[bg].settings.bg_secondary_color | color_darken:10 }};display:flex;display:-webkit-flex;justify-content:space-evenly;position:relative;padding: 20px 0px;{% if section.settings.ellipsis %}padding-left: 5px;padding-right: 5px;{% endif %}} 
  .cartItems__container:first-child{border-top:0;}
  .cartItems__container.discounted {margin-bottom:25px}
  .cartItems__container.discounted-lastRow {margin-bottom:40px}
  /* & image */ 
  .cartItems__image {margin-right:10px;display: flex;align-items: center;}
  .cartItems__image img { {% if section.blocks[bg].settings.img_border %}border:1px solid {{ section.blocks[bg].settings.bg_secondary_color | color_darken:12 | color_modify: 'alpha', wrapper_opacity }};{% endif %}display:block;border-radius: 5px;width:{{ 90 | times: font_size_mobile }}px;height:{{ 90 | times: font_size_mobile }}px;object-fit: cover;}
  .cartItems__image a {margin:0;display:inline-block;width:{{ 90 | times: font_size_mobile }}px;}
  /* & infos */
  .cartItems__infos {width:calc(100% - 90px);display: flex;flex-direction: column;justify-content: space-around;color:inherit;font-size:0.9em}
  .cartItems__title {color:{{ section.blocks[bg].settings.primary_color_mobile }};line-height: 1em;}
  .cartItems__title > * {margin-bottom:7px}
  .cartItems__title > a { {% if section.settings.ellipsis %}white-space: nowrap;overflow: hidden;text-overflow: ellipsis;{% endif %}margin-bottom:5px;display:block;font-weight:700;color:inherit;}
  .cartItems__title p {color:{{ section.blocks[bg].settings.primary_color_mobile }};margin:0 0 7px 0; line-height:1em;}
  .cartItems__infos .flash__text {margin-top: auto;margin-bottom: 0;color:{{ section.settings.flashtext_color }}}
  .cartItems__infos .flash__text p{font-size:0.8em;font-weight:600;}
   .cartItems__infos .flash__text > * {color:{{ section.settings.flashtext_color }};fill:{{ section.settings.flashtext_color }} }
  /* & quantity */
  .cartItems__quantity {position:absolute;right:0;bottom:20px}
  .cartItems__quantity .cartItems__quantity--controls {display: inline-flex;width: 75px;border: 1px solid #dbdbdb;height: 32px;}
  .cartItems__quantity .cartItems__quantity--controls > * {all:unset;width:29px;padding:0;text-align:center;border:0;color:#777777;background-color:#fff}  
  .cartItems__quantity .cartItems__quantity--controls > input {width:17px;}
  .cartItems__quantity .cartItems__quantity--controls > button {cursor:pointer;outline:none}
  .cartItems__quantity .cartItems__quantity--controls > button:active {background-color: #eeeeee;transition:all 0.1s ease-out}
  /* & price & compare at price & discounts */
  .cartItems__prices {font-size:1.3em;line-height:1em}
  .cartItems__prices del{position:relative;text-decoration:none;margin-right:6px;display:inline-block}
  .cartItems__prices del:before {content: "";display: block;width: 100%;border-top: 2px solid #c76f6f;position: absolute;height:0.6em;bottom: 0;left: 0;transform: rotate(-13.4deg);}
  .cartItems__prices .cents{font-size:60%;vertical-align:55%;display:inline-block;line-height:100%;}
  .cartItems__prices-compare .cents, .cartItems__prices-original .cents{vertical-align:45%}
  .cartItems__prices-compare,  .cartItems__prices-original {font-size:0.8em;color:gray}
  .cartItems__prices-total{display:inline-block;font-weight:400;margin-right:15px;color:{{ section.blocks[bg].settings.primary_color_mobile }};}
  .cartItems__prices-container {display:flex;display: -webkit-flex;flex-direction: column-reverse;justify-content: space-evenly;}
  .cartItems__prices-discount{font-size:1em;bottom:-10px;left:0;width:100%;margin-bottom:0;}
  .cartItems__prices-discount li{color:{{ section.blocks[savings].settings.discount_text_color }};display:inline-block;text-align:left;font-weight:700;background-color: {{ section.blocks[savings].settings.discount_bg_color }};{% if section.blocks[savings].settings.discount_bg_color contains 'rgba(0,0,0,0)' %}padding: 4px 5px 4px 0;{% else %}padding: 4px 5px;{% endif %}line-height:1em;width:auto;border-radius:3px}
  .cartItems__prices-discount.mobileAbsolute {position:absolute}
  .cartItems__prices-discount:not(.mobileAbsolute) + .flash__text {display:none}
  .cartItems__prices--smaller {font-size:1.15em}
  
  /* TABLE RIGHT */
  /* & container */
  .summary__wrapper{width:100%;text-align:center;padding:0 20px 20px;display:block;position:relative;text-align:right;background-color:{{ section.blocks[bg].settings.bg_secondary_color | color_modify: 'alpha', wrapper_opacity }};}
  /* total & subtotal */
  .tva-incluse{font-size:0.95em;color:{{ section.settings.custom_text1_color }};font-weight:300;text-align:left;height: 1em;margin:3px 0 0 0;}
  .summary__subtotal{padding-top: 20px;margin:0 0 -5px 0;display:flex;display: -webkit-flex;line-height:1;justify-content:space-between;font-size: 1.6em;font-weight: 600;color:{{ section.settings.total_color }};}
  .summary__subtotal .cents {font-size:60%;vertical-align:50%;display:inline-block;line-height:100%;}
  .summary__price {font-size:1.1em}
  /* & custom text */
  .basket-sep{border-top:1px dashed {{ section.blocks[bg].settings.bg_secondary_color | color_darken:12 }};border-bottom:0;border-style:dashed;border-color:{{ section.blocks[bg].settings.bg_secondary_color | color_darken:12 }};margin:15px 0;clear:both;float:none;}
  .custom__text p {text-align:center;color:{{ section.blocks[customtext].settings.custom_text2_color }};margin:0}
  /* & savings */
  .summary__savings {margin:10px 0 0;}
  .summary__savings p {text-align:right;font-weight:600}
  /* & cart btn */
  .btnCart{position:relative;margin:0;height:50px;color:{{ section.settings.button_text_color }};background-color:{{ section.settings.button_bg_color }};display:inline-block;width:auto;text-decoration:none;text-align:center;vertical-align:middle;white-space:nowrap;cursor:pointer;border:1px solid transparent;-moz-user-select:none;-ms-user-select:none;-webkit-user-select:none;user-select:none;-webkit-appearance:none;-moz-appearance:none;appearance:none;letter-spacing:1.5px;width:100%;font-weight:600; border-radius:50px;font-size:1em;padding:12px 20px;transition:color 0.1s ease-in,background-color 0.1s ease-in;}
  .btnCart:hover, .btnCart:active, .btnCart:focus{background-color:{{ btn_color_hover }};border:1px solid {{ btn_color_hover }};outline:none}
  .btn__svg--loader {position: absolute;fill:{{ section.settings.button_text_color }};width: 20px;height: 20px;left: calc(50% - 10px);top: calc(50% - 10px);-webkit-transition: opacity 0.3s ease-in-out;transition: opacity 0.3s ease-in-out;opacity: 0;}
  .btn__svg--loader.btn__svg--loading {-webkit-animation: rotate 0.5s linear infinite;animation: rotate 0.5s linear infinite;opacity: 1;}
  .btnCart.btnCart--loading {pointer-events:none}
  .btnCart.btnCart--loading span {opacity:0;transition: opacity 0.2s ease-out;}
   @keyframes rotate {0% {-webkit-transform: rotate(0);transform: rotate(0);}100% {-webkit-transform: rotate(360deg);transform: rotate(360deg);}}

  /* EXTRA STYLES & EFFECTS */
  {% if section.settings.flashtext_blink %}
  .blinking{animation:blinkingText 1.5s infinite;animation-delay:1s}
  @keyframes blinkingText{20%{opacity:1}50%{opacity:0}100%{opacity:1}}
  {% endif %}
  #shopify-section-{{ section.id }}::-webkit-input-placeholder{color:#3d3d3d!important;}
  #shopify-section-{{ section.id }}::-moz-placeholder{color:#3d3d3d!important;} 

  {% if section.blocks[savings].settings.promofield_enable %}
  /* PROMO CODE */
  .discount_Field{width:100%;display: block;position: relative;text-align: right;cursor: pointer}
  .discount_Field span {display:flex;display: -webkit-flex;align-items:center;margin-bottom:15px;padding: 3px 0;}
  .discount_Field svg{float:left;width:31px;height:auto;margin-right:15px}
  #shopify-section-{{ section.id }} input.checkoutcode{height:38px;border-radius:7px;border: solid 1px;background-color:#fff;border-color: #E7E7E7;margin-bottom:0;padding:8px 10px;width:100%;color:#191919;font-size:1em;}
  #shopify-section-{{ section.id }} input.checkoutcode:focus{outline:none;border:1px solid {{ section.blocks[savings].settings.promofield_color }};box-shadow:0 0 0 1px {{ section.blocks[savings].settings.promofield_color }};transition:all .2s ease-out}
  .discount_Field--text{margin:-15px 0 0;color:#ec6464;font-size:0.9em;max-height: 0px;opacity: 0;transition: all 0.7s ease-out;}
  .discount_Field--text.show {max-height:40px;opacity:1}
  {% endif %}
  
  /* CDTIMER */
  #cdTimerCart {text-align:left;font-size:18px;color:{{ section.blocks[timer].settings.cart_timer_color1 }} }
  #cdTimerCart .cdTimerCart--color {color:{{ section.blocks[timer].settings.cart_timer_color2 }} }

  {% if section.blocks[badges].settings.badges_enable %}
  /* TRUST BADGES */
  .secure-pay-cart{font-size:0.92em;margin:2px auto 0;display:table;color:{{ section.blocks[badges].settings.badges_color }};filter:grayscale(0.1);text-align:center;clear:right}
  .secure-pay-cart svg:not(:nth-of-type(1)){vertical-align:middle}
  .secure-pay-cart svg.cb{width:24px;margin-left:7px}
  .secure-pay-cart svg.applepay{width:38px;margin-left:5px}
  .secure-pay-cart svg.visa{width:37px;margin-left:3px}
  .secure-pay-cart svg.mastercard{width:32px;margin-left:3px}
  .secure-pay-cart svg.paypal{width:64px;margin-left:5px}
  .secure-pay-cart svg.amex{width:26px;margin-left:5px}
  .lockicon{margin-right:3px}  
  .secure-pay-cart > span > span {display:inline-block; margin-bottom:10px; vertical-align:text-top;line-height:100%}
  {% endif %}

  {% if section.settings.show_notes %}
  /* CART NOTES */
  .cart_notes{text-align:center}
  .cart_notes label {text-transform:none;letter-spacing: 0;font-size: 1em;color:{{ section.blocks[customtext].settings.custom_text2_color }} }
  .cart_notes textarea{display:block;background-color:#fff;width:100%; border-color:#e9e7e7;margin:5px 0 20px;padding: 10px;height: 100px;min-height:100px;}
  .cart_notes textarea::-webkit-input-placeholder{color: #c4c4c4!important;opacity: 1;}
  .cart_notes textarea::-moz-placeholder{color: #c4c4c4!important;opacity: 1;}
  {% endif %}
  
  /* UPSELL */
  .upsell_section-editor {background-color:#649eff;color:#fff;font-weight: 600;text-align: center;margin: 70px 60px;padding: 5px 10px;order:2}
  .upsell-svg.submit_upsell ellipse{fill:{{ section.settings.button_bg_color }};}

    .formob{
    display:none;
  }
  .fordesk{
    display:block;
  }
  
  /* MEDIA QUERIES */
  @media (min-width: 1100px){
    {% capture wrapper_opacity %}{{ section.blocks[bg].settings.bg_secondary_opacity_desktop | divided_by: 100.0 }}{% endcapture %}
    {% assign wrapper_opacity = wrapper_opacity | plus: 0 %}
    #shopify-section-{{ section.id }} {font-size:{{ font_size_desktop }}em;}
    #shopify-section-{{ section.id }}::after {content:"";{% if section.blocks[bg].settings.bg_img_desktop == blank %}background-color:{{ section.blocks[bg].settings.bg_color_desktop }};{% else %}background:url('{{ section.blocks[bg].settings.bg_img_desktop | img_url: '1400x', format: 'pjpg' }}');{% endif %};opacity: {{ section.blocks[bg].settings.bg_opacity_desktop | divided_by: 100.0 }};top: 0;left: 0;bottom: 0;right: 0;position:absolute;z-index: -1;background-size:cover;background-repeat:no-repeat;background-position:{{ section.blocks[bg].settings.bg_poshorizontal_desktop }}% {{ section.blocks[bg].settings.bg_posvertical_desktop}}%}
    form[name="cartForm"] {display:flex;display:-webkit-flex;align-items:flex-start;justify-content:flex-start;flex-wrap:wrap;}
    .md_desktop-hide {display:none}
    .md_mobile-hide {display:inherit}
    .summary__wrapper {background-color:{{ section.blocks[bg].settings.bg_secondary_color_desktop | color_modify: 'alpha', wrapper_opacity }};width:30%;margin-left:2%;float:right;margin-top:0;position:sticky;top:100px;}    
    .cartItems__wrapper {width: 100%;float: left;background-color:{{ section.blocks[bg].settings.bg_secondary_color_desktop | color_modify: 'alpha', wrapper_opacity }};padding: 15px 20px;}
    .cartItems__container {border-top: 1px solid {{ section.blocks[bg].settings.bg_secondary_color_desktop | color_darken:10 }}}   
    .basket-sep{border-top:1px dashed {{ section.blocks[bg].settings.bg_secondary_color_desktop | color_darken:12 }}}
    .pageWidth{padding:75px 20px 100px;margin:0 auto}
    .checkoutsteps {margin:0 auto 60px;font-size:1em;padding-top:0}
    #shopify-section-{{ section.id }} input.checkoutcode{height:42px;}
    .checkoutcode{padding:6px 10px;}
    .cartItems__container{min-height:150px}
    .cartItems__container:first-child{padding-top:22px}
    .cartItems__image img {width:95px;height:auto;{% if section.blocks[bg].settings.img_border %}border:2px solid {{ section.blocks[bg].settings.bg_secondary_color_desktop | color_darken:12 | color_modify: 'alpha', wrapper_opacity }}{% endif %};}
    .cartItems__image a {width: 95px;}
    .cartItems__container.discounted, .cartItems__container.discounted-lastRow {margin-bottom:0px}
    .cartItems__infos {flex-direction: row;align-items: center;justify-content: space-between;font-size:1em}
    .cartItems__title{width:310px;font-size:1em;display:flex;display:-webkit-flex;flex-direction:column;justify-content:{% if section.settings.flashtext != blank %}space-between{% else %}space-evenly{% endif %};min-height:60px;color:{{ section.blocks[bg].settings.primary_color_desktop }} }
    .cartItems__title--height {min-height:80px;}
    .cartItems__title a{white-space: normal;}
    .cartItems__quantity {position:inherit}
    .cartItems__quantity .cartItems__quantity--controls{height:35px}
    .cartItems__prices {width:175px;text-align:right}
    .cartItems__prices .cents{vertical-align:45%}
    .cartItems__prices--smaller {font-size:1.25em}
    .cartItems__prices-discount {position:relative!important;bottom:0}
    .cartItems__prices-discount li {margin-bottom:5px;margin-top:5px}
    .cartItems__prices-discount + .flash__text {display:none}
    .cartItems__title p, .cartItems__prices-total {color:{{ section.blocks[bg].settings.primary_color_desktop }} }
    .cart-message__wrapper {margin:0px 0px 45px;padding:10px 20px;border-radius:7px}
    .secure-pay-cart{margin:12px auto 0;}
    .summary__savings {margin:10px 0;}
  }
  @media (max-width:1099px) and (min-width:640px) {
    .summary__wrapper, .cartItems__wrapper{width:640px;margin:auto;}
  }
  @media (max-width: 1099px){
    #shopify-section-{{ section.id }}::after{content: "";{% if section.blocks[bg].settings.bg_img == blank %}background-color:{{ section.blocks[bg].settings.bg_color }};{% else %}background:url('{{ section.blocks[bg].settings.bg_img | img_url: '800x', format: 'pjpg' }}');{% endif %}opacity: {{ section.blocks[bg].settings.bg_opacity | divided_by: 100.0 }};top: 0;left: 0;bottom: 0;right: 0;position:absolute;z-index: -1;background-size:cover;background-repeat:no-repeat;background-position:{{ section.blocks[bg].settings.bg_poshorizontal }}% {{ section.blocks[bg].settings.bg_posvertical }}%}
    .summary__wrapper{margin:15px auto;  width:90%; border-radius:7px; }
    .btnCart__sticky{position: sticky;bottom: 0px;width: 90vw;margin-left: calc(50% - 45vw);padding:15px 20px;background-color:{{ section.blocks[bg].settings.bg_secondary_color }};}
    .btnCart__sticky.btnCart__sticky--shadow {box-shadow:0px -2px 5px -2px rgba(5,5,5,0.15);transition:all 0.2s ease-in-out}
    .sticky_sentinel--bottom {position:relative;height: 3px;bottom:-19px;}
    .scroll__observer {position: absolute;width: 1px;height: 1px;top: -92px;left: 0;}
     #shopify-section-upsell-maxdesign {padding-bottom:20px;transition:padding 0.5s ease-out 0.7s;}
    #cdTimerCart {font-size:15px;}
    .cart-message__text{font-size:12px;}
    .cart-message__wrapper {margin:15px auto;padding:10px 20px;border-radius:7px;background-color:#ffffff;width:90%}
    .cartItems__wrapper {width:90%;margin:auto;border-radius:7px}
    .custom__text{width: 90%;margin: 15px auto;border-radius: 7px;background-color: #fff;padding: 10px 20px;}
     .formob{
    display:block;
  }
  .fordesk{
    display:none;
  }

  }

  /* CUSTOM CSS */
  @media (min-width:{{ section.blocks[customcss].settings.query }}px) { {{ section.blocks[customcss].settings.css_bureau }} }
  @media (max-width:{{ section.blocks[customcss].settings.query }}px) { {{ section.blocks[customcss].settings.css_mobile }} }

  .indicator--green {
    position: relative;
    display: block;
    height: 10px;
    width: 10px;
    aspect-ratio: 1;
    background: #0da558;
    border-radius: 50%;
    margin-top: 5px;
}

  .indicator--green:before {
    content: "";
    display: block;
    height: 14px;
    width: 14px;
    aspect-ratio: 1;
