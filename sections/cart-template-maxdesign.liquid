        {%- endfor -%}
        {%- assign sorted_cart_items = items_to_sort | sort: 'price' | reverse | concat: items_to_append -%}
        {% for item in sorted_cart_items %}
        {% assign lastloop = forloop.last %}
        <div class="cartItems__container {% for discount in item.discounts %}{% assign discount_available = true %}{% if lastloop %}discounted-lastRow{% elsif discount.title.size > 15 %}discounted{%endif %}{% endfor %}" id="{{item.variant.id}}">          
