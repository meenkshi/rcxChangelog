                    <tr><td>{{ t_securite }}</td><td>{{ block.settings.t2_r3_c1 }}</td><td>{{ block.settings.t2_r3_c2 }}</td></tr>
                    <tr><td>{{ t_prix }}</td><td>{{ block.settings.t2_r4_c1 }}</td><td>{{ block.settings.t2_r4_c2 }}</td></tr>
                  </tbody>
