      {% when 'faq_additional' %}
        <div class="rcx-faq-single" {{ block.shopify_attributes }} style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px; --pt-mob: {{ block.settings.padding_top_mobile }}px; --pb-mob: {{ block.settings.padding_bottom_mobile }}px;" data-rcx-block>
           <div class="rcx-max">
             <div class="{% if block.settings.enable_grid %}rcx-grid rcx-grid-2{% else %}rcx-stack-24{% endif %}">
               {% for i in (1..4) %}
                 {% capture q_key %}q_{{i}}{% endcapture %}
                 {% capture a_key %}a_{{i}}{% endcapture %}
                 {% if block.settings[q_key] != blank %}
                   <div class="rcx-card rcx-faq-item">
                     <div class="rcx-card-hd">
                       <h3 class="rcx-h3">{{ block.settings[q_key] }}</h3>
                       <span class="rcx-ico rcx-ico-chevron"></span>
                     </div>
                     <div class="rcx-card-bd">
                       {{ block.settings[a_key] | replace: '<p', '<p class="rcx-faq-answer"' | replace: '<ul', '<ul class="rcx-faq-answer"' }}
                     </div>
