                </div>
              {% endfor %}
            </div>
          </div>
        </div>

      {% when 'reviews' %}
        <div class="rcx-max" {{ block.shopify_attributes }} style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px; --pt-mob: {{ block.settings.padding_top_mobile }}px; --pb-mob: {{ block.settings.padding_bottom_mobile }}px;" data-rcx-block>
          <h2 class="rcx-h2" style="margin-bottom: {{ block.settings.heading_spacing }}px; --fs-desktop: {{ block.settings.heading_size }}px; --fs-mobile: {{ block.settings.heading_size_mobile }}px;" data-rcx-heading>{{ block.settings.heading }}</h2>
          <div class="rcx-grid rcx-grid-3">
            {% for i in (1..3) %}
              {% capture img_key %}image_{{i}}{% endcapture %}
              {% capture name_key %}name_{{i}}{% endcapture %}
              {% capture title_key %}title_{{i}}{% endcapture %}
              {% capture text_key %}text_{{i}}{% endcapture %}
              <div class="rcx-card">
                <img src="{{ block.settings[img_key] | image_url: width: 600 }}" alt="Avis client {{i}}" class="rcx-review-img" loading="lazy" style="height: {{ block.settings.image_height }}px" />
                <div class="rcx-card-bd">
                  <div style="display:flex;align-items:center;gap:8px;font-weight:700">
                    {{ block.settings[name_key] }}
                    <span style="font-size:12px;background:#e0e7ff;color:#1e3a8a;padding:3px 6px;border-radius:6px">{{ block.settings.verified_label }}</span>
                  </div>
                  <div class="rcx-h4" style="margin-top:6px">{{ block.settings[title_key] }}</div>
                  <p class="rcx-muted">{{ block.settings[text_key] }}</p>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

      {% when 'faq_group' %}
        <div class="rcx-faq" {{ block.shopify_attributes }} style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px; --pt-mob: {{ block.settings.padding_top_mobile }}px; --pb-mob: {{ block.settings.padding_bottom_mobile }}px;" data-rcx-block>
          <div class="rcx-max">
            <h2 class="rcx-h2" style="margin-bottom: {{ block.settings.heading_spacing }}px; --fs-desktop: {{ block.settings.heading_size }}px; --fs-mobile: {{ block.settings.heading_size_mobile }}px;" data-rcx-heading>{{ block.settings.heading }}</h2>
            <div class="rcx-grid rcx-grid-2">
              {% for i in (1..5) %}
                {% capture q_key %}q_{{i}}{% endcapture %}
                {% capture a_key %}a_{{i}}{% endcapture %}
                {% if block.settings[q_key] != blank %}
                  <div class="rcx-card rcx-faq-item">
                    <div class="rcx-card-hd">
                      <h3 class="rcx-h3">{{ block.settings[q_key] }}</h3>
                      <span class="rcx-ico rcx-ico-chevron"></span>
                    </div>
                    <div class="rcx-card-bd">
                      {{ block.settings[a_key] | replace: '<p', '<p class="rcx-faq-answer"' | replace: '<ul', '<ul class="rcx-faq-answer"' }}
                    </div>
