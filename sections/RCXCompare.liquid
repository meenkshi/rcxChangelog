{% when 'comparison' %}
        {%- case request.locale.iso_code -%}
          {%- when 'en' -%}
            {%- assign t_criterie = 'Criterion' -%}{%- assign t_vitesse = 'Speed' -%}{%- assign t_entretien = 'Maintenance' -%}{%- assign t_prix = 'Price' -%}{%- assign t_resistance = 'Resistance' -%}{%- assign t_autonomie = 'Range' -%}{%- assign t_poids = 'Weight' -%}{%- assign t_securite = 'Safety' -%}
          {%- when 'de' -%}
            {%- assign t_criterie = 'Kriterium' -%}{%- assign t_vitesse = 'Geschwindigkeit' -%}{%- assign t_entretien = 'Wartung' -%}{%- assign t_prix = 'Preis' -%}{%- assign t_resistance = 'Widerstand' -%}{%- assign t_autonomie = 'Reichweite' -%}{%- assign t_poids = 'Gewicht' -%}{%- assign t_securite = 'Sicherheit' -%}
          {%- when 'es' -%}
            {%- assign t_criterie = 'Criterio' -%}{%- assign t_vitesse = 'Velocidad' -%}{%- assign t_entretien = 'Mantenimiento' -%}{%- assign t_prix = 'Precio' -%}{%- assign t_resistance = 'Resistencia' -%}{%- assign t_autonomie = 'Autonomía' -%}{%- assign t_poids = 'Peso' -%}{%- assign t_securite = 'Seguridad' -%}
          {%- when 'nl' -%}
            {%- assign t_criterie = 'Criterium' -%}{%- assign t_vitesse = 'Snelheid' -%}{%- assign t_entretien = 'Onderhoud' -%}{%- assign t_prix = 'Prijs' -%}{%- assign t_resistance = 'Weerstand' -%}{%- assign t_autonomie = 'Bereik' -%}{%- assign t_poids = 'Gewicht' -%}{%- assign t_securite = 'Veiligheid' -%}
          {%- when 'sv' -%}
            {%- assign t_criterie = 'Kriterium' -%}{%- assign t_vitesse = 'Hastighet' -%}{%- assign t_entretien = 'Underhåll' -%}{%- assign t_prix = 'Pris' -%}{%- assign t_resistance = 'Motstånd' -%}{%- assign t_autonomie = 'Räckvidd' -%}{%- assign t_poids = 'Vikt' -%}{%- assign t_securite = 'Säkerhet' -%}
          {%- else -%}
            {%- assign t_criterie = 'Critère' -%}{%- assign t_vitesse = 'Vitesse' -%}{%- assign t_entretien = 'Entretien' -%}{%- assign t_prix = 'Prix' -%}{%- assign t_resistance = 'Résistance' -%}{%- assign t_autonomie = 'Autonomie' -%}{%- assign t_poids = 'Poids' -%}{%- assign t_securite = 'Sécurité' -%}
