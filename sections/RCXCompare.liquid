          data-pro-bullets="{{ block.settings.pro_bullets }}"
        >
          <div class="rcx-stack-24">
            <div class="rcx-grid rcx-grid-3">
              <div class="rcx-card rcx-col-span-2">
                <div class="rcx-card-hd"><h3 class="rcx-h3" style="margin-bottom: {{ block.settings.heading_spacing }}px; --fs-desktop: {{ block.settings.heading_size }}px; --fs-mobile: {{ block.settings.heading_size_mobile }}px;" data-rcx-heading>{{ block.settings.heading }}</h3></div>
                <div class="rcx-card-bd">
                  <div class="rcx-grid rcx-grid-3">
                    
                    <!-- Niveau -->
                    <div class="rcx-field" data-name="niveau">
                      <label>{{ block.settings.lbl_level }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="debutant">{{ block.settings.opt_level_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="intermediaire">{{ block.settings.opt_level_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="expert">{{ block.settings.opt_level_3 }}</button>
                      </div>
                    </div>

                    <!-- Terrain -->
                    <div class="rcx-field" data-name="terrain">
                      <label>{{ block.settings.lbl_terrain }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="urbain">{{ block.settings.opt_terrain_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="offroad">{{ block.settings.opt_terrain_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="mixte">{{ block.settings.opt_terrain_3 }}</button>
                      </div>
                    </div>

                    <!-- Vitesse -->
                    <div class="rcx-field" data-name="vitesse">
                      <label>{{ block.settings.lbl_vitesse }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="douce">{{ block.settings.opt_vitesse_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="moyenne">{{ block.settings.opt_vitesse_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="elevee">{{ block.settings.opt_vitesse_3 }}</button>
                      </div>
                    </div>

                    <!-- Usage -->
                    <div class="rcx-field" data-name="usage">
                      <label>{{ block.settings.lbl_usage }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="enfant">{{ block.settings.opt_usage_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="loisir">{{ block.settings.opt_usage_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="sensations">{{ block.settings.opt_usage_3 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="competition">{{ block.settings.opt_usage_4 }}</button>
                      </div>
                    </div>

                    <!-- Autonomie -->
                    <div class="rcx-field" data-name="autonomie">
                      <label>{{ block.settings.lbl_autonomie }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="compacte">{{ block.settings.opt_autonomie_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="standard">{{ block.settings.opt_autonomie_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="longue">{{ block.settings.opt_autonomie_3 }}</button>
                      </div>
                    </div>

                    <!-- Budget -->
                    <div class="rcx-field" data-name="budget">
                      <label>{{ block.settings.lbl_budget }}</label>
                      <div class="rcx-choices">
                        <button type="button" class="rcx-chipopt" data-opt="moins-100">{{ block.settings.opt_budget_1 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="100-150">{{ block.settings.opt_budget_2 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="150-250">{{ block.settings.opt_budget_3 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="250-400">{{ block.settings.opt_budget_4 }}</button>
                        <button type="button" class="rcx-chipopt" data-opt="400+">{{ block.settings.opt_budget_5 }}</button>
                      </div>
                    </div>

                  </div>
                </div>
              </div>

              <div class="rcx-card rcx-card-reco">
                <div class="rcx-card-hd">
                  <h3 class="rcx-h3" style="font-weight:700;">{{ block.settings.reco_heading }}</h3>
                </div>
                <div class="rcx-card-bd">
                  <div class="rcx-reco-outer">
                    <div class="rcx-reco-box">
