      {% when 'gammes' %}
        <div class="gamme-section" {{ block.shopify_attributes }} style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px; --pt-mob: {{ block.settings.padding_top_mobile }}px; --pb-mob: {{ block.settings.padding_bottom_mobile }}px;" data-rcx-block>
