                        <img id="reco-image" src="{{ block.settings.go_image | image_url: width: 320 }}" alt="Recommended RC" class="rcx-reco-img" width="120" height="80" loading="lazy" style="width: {{ block.settings.reco_img_width }}px" />
                        <div class="rcx-reco-main">
