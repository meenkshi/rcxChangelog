</section>

<script>
(function(){
  var answers = { niveau:'debutant', terrain:'mixte', vitesse:'moyenne', usage:'loisir', autonomie:'standard', budget:'100-150' };
  // Scoped selection to this section to avoid conflicts
  var sel = document.querySelector('.section-{{ section.id }} .rcx-selector-container');
  
  function $all(s, r){return Array.prototype.slice.call((r||document).querySelectorAll(s))}

  // UI binding
  if(sel){
    $all('.rcx-field', sel).forEach(function(f){
      var name = f.getAttribute('data-name');
      $all('[data-opt]', f).forEach(function(btn){
        var val = btn.getAttribute('data-opt');
        btn.addEventListener('click', function(e){
          e.preventDefault();
          answers[name] = val;
          $all('[data-opt]', f).forEach(function(b){ b.classList.remove('active'); });
          btn.classList.add('active');
          updateReco();
        });
      });
    });
  }

  function scoreReco(x){
    if (x.budget === 'moins-100') return 'go';
    if (x.budget === '100-150')  return 'max';
    if (x.budget === '150-250' || x.budget === '250-400' || x.budget === '400+') return 'pro';

    var s = { go:0, max:0, pro:0 };
    if (x.niveau === 'debutant')       s.go += 2;
    if (x.niveau === 'intermediaire')  s.max  += 2;
    if (x.niveau === 'expert')         s.pro   += 2;
    if (x.vitesse === 'douce')         s.go += 2;
    if (x.vitesse === 'moyenne')       s.max  += 1;
    if (x.vitesse === 'elevee')        s.pro   += 2;
    if (x.terrain === 'urbain')        s.go += 1;
    if (x.terrain === 'mixte')         s.max  += 1;
    if (x.terrain === 'offroad')       s.pro   += 3;
    var best='max', v=-1; for (var k in s){ if (s[k] > v){ best=k; v=s[k]; } }
    return best;
  }

  function buildReco(tag){
    // Read settings from data attributes on container
    if(!sel) return {};
    var d = sel.dataset;
    var map = {
      go: { img: d.goImg, link: d.goLink, name: d.goName, sub: d.goSub, bullets: d.goBullets },
      max: { img: d.maxImg, link: d.maxLink, name: d.maxName, sub: d.maxSub, bullets: d.maxBullets },
      pro: { img: d.proImg, link: d.proLink, name: d.proName, sub: d.proSub, bullets: d.proBullets }
    };
    
    var t = map[tag] || map['max'];

    return {
      image: t.img,
      link:  t.link,
      name:  t.name,
      sub:   t.sub,
      bullets: t.bullets ? t.bullets.split(',').map(function(s){return s.trim()}) : []
    };
  }

  function updateReco(){
    if(!sel) return;
    var tag = scoreReco(answers);
    var r = buildReco(tag);
    var img = document.getElementById('reco-image');
    var name = document.getElementById('reco-name');
    var sub = document.getElementById('reco-sub');
    var link = document.getElementById('reco-link');
    var ul = document.getElementById('reco-bullets');

    if (img && r.image) img.src = r.image;
    if (name) name.textContent = r.name;
    if (sub)  sub.textContent  = r.sub;
    if (link) link.href        = r.link;

    if (ul){
      ul.innerHTML = '';
      r.bullets.forEach(function(b){
        var li = document.createElement('li');
        var ico = document.createElement('span');
        ico.textContent = '✅';
        ico.className = 'rcx-emoji-ico';
        var txt = document.createElement('span');
        txt.textContent = b;
        li.appendChild(ico); li.appendChild(txt);
        ul.appendChild(li);
      });
    }
  }

  // Init Selector
  if(sel){
    $all('.rcx-field', sel).forEach(function(f){
      var name = f.getAttribute('data-name');
      var def = answers[name];
      var target = f.querySelector('[data-opt="' + def + '"]') || f.querySelector('[data-opt]');
      if(target) target.classList.add('active');
    });
    updateReco();
  }

  // FAQ Toggle Logic
  $all('.section-{{ section.id }} .rcx-faq-item .rcx-card-hd').forEach(function(hd){
    hd.addEventListener('click', function(){
      this.parentElement.classList.toggle('active');
    });
  });

})();
</script>

