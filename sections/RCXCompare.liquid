            <div>
              <h2 class="rcx-h2 rcx-h2-light" style="margin-bottom: {{ block.settings.heading_spacing }}px; --fs-desktop: {{ block.settings.heading_size }}px; --fs-mobile: {{ block.settings.heading_size_mobile }}px;" data-rcx-heading>{{ block.settings.heading }}</h2>
