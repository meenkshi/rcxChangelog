              <a class="rcx-btn rcx-btn-light" href="{{ block.settings.link_2 }}">{{ block.settings.label_2 }}</a>
              <a class="rcx-btn rcx-btn-light" href="{{ block.settings.link_3 }}">{{ block.settings.label_3 }}</a>
            </div>
