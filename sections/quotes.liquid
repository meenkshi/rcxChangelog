{% style %}

.cusreview-userimg {
	display: flex;
	justify-content: center;
}

.newImage {
	border-radius: 50%;
}

.quote1 p {
 color: #FFFFFF;
}

#section-{{ section.id }} {
    background: #000000;
        padding: 25px 0;
}

h1, h2, cite {
	color: #FFFFFF;
}

{% endstyle %}


<div id="section-{{ section.id }}">
<section class="page-width" data-section-id="{{ section.id }}" data-section-type="quotes">
  {% if section.settings.title != blank %}
    <div class="section-header text-center">
      <h2>{{ section.settings.title | escape }}</h2>
      <h1>{{ section.settings.subtitle | escape }}</h1>
    </div>
  {% endif %}

  {% if section.blocks.size > 0 %}
    <div class="quotes-wrapper">
      <div class="quotes-slider" id="Quotes-{{ section.id }}" data-count="{{ section.blocks.size }}">
        {% for block in section.blocks %}
          <div class="quotes-slide--{{ block.id }} itemnew1" {{ block.shopify_attributes }}>
            <blockquote class="quotes-slider__text text-center">
              {% comment %}
              <span class="quote-icon">{% include 'icon-quote' %}</span> 
              {% endcomment %}
              
              <div class="cusreview-userimg" >
                  <img src="{{ block.settings.review_image | img_url: '200x200' }}" class="newImage">
          	  </div>
              
              <div style="margin: 20px;">
                  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="30" height="30" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve">
                      <polygon points="512,197.816 325.961,185.585 255.898,9.569 185.835,185.585 0,197.816 142.534,318.842 95.762,502.431     255.898,401.21 416.035,502.431 369.263,318.842   " fill="#fff" data-original="#000000"></polygon>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="30" height="30" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve">
                      <polygon points="512,197.816 325.961,185.585 255.898,9.569 185.835,185.585 0,197.816 142.534,318.842 95.762,502.431     255.898,401.21 416.035,502.431 369.263,318.842   " fill="#fff" data-original="#000000"></polygon>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="30" height="30" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve">
                      <polygon points="512,197.816 325.961,185.585 255.898,9.569 185.835,185.585 0,197.816 142.534,318.842 95.762,502.431     255.898,401.21 416.035,502.431 369.263,318.842   " fill="#fff" data-original="#000000"></polygon>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="30" height="30" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve">
                      <polygon points="512,197.816 325.961,185.585 255.898,9.569 185.835,185.585 0,197.816 142.534,318.842 95.762,502.431     255.898,401.21 416.035,502.431 369.263,318.842   " fill="#fff" data-original="#000000"></polygon>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:svgjs="http://svgjs.com/svgjs" width="30" height="30" x="0" y="0" viewBox="0 0 512 512" style="enable-background:new 0 0 512 512" xml:space="preserve">
                      <polygon points="512,197.816 325.961,185.585 255.898,9.569 185.835,185.585 0,197.816 142.534,318.842 95.762,502.431     255.898,401.21 416.035,502.431 369.263,318.842   " fill="#fff" data-original="#000000"></polygon>
                  </svg>
              </div>
                
              {% if block.settings.quote != blank %}
              <div class="rte-setting rte quote1">
                <p>{{ block.settings.quote }}</p>
              </div>
              {% endif %}
              {% if block.settings.author != blank %}
              <cite><h2><strong>{{ block.settings.author | escape }}</strong></h2></cite>
              {% endif %}
            </blockquote>
            <div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.blocks.size == 0 %}
    {% include 'no-blocks' %}
  {% endif %}
  
</section>
</div>



