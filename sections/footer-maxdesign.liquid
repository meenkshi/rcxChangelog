{% for block in section.blocks -%}
  {%- if block.type == 'developer' -%}
    {%- assign developer = forloop.index0 -%}
  {%- elsif block.type == 'social' -%}
    {%- assign social = forloop.index0 -%}
  {%- elsif block.type == 'logo' -%}
    {%- assign logo = forloop.index0 -%}
  {%- endif -%}
{%- endfor %}
{% if developer != null -%}
  {%- assign breakPoint = section.blocks[developer].settings.query -%}
{%- else -%}
  {%- assign breakPoint = 750 -%}
{%- endif %}
{% assign btn_brightness = section.settings.color | color_brightness | plus: 0 | round %}
{% if btn_brightness > 40 and btn_brightness != 255 -%}
  {%- assign btn_color_hover = section.settings.color | color_darken: 15 -%}
{%- else -%}
  {%- assign btn_color_hover = section.settings.color | color_lighten: 15 -%}
{%- endif %}
{% if section.blocks[social].settings.enable %}
  {% capture social_networks %}
