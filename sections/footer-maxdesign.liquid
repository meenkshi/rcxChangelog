<style>
    /* section & wrapper */
    #shopify-section-{{ section.id }} {margin-top:{{ section.settings.spacing_top_mobile }}px;margin-bottom:{{ section.settings.spacing_bottom_mobile }}px;user-select:none}
    #shopify-section-{{ section.id }} .footer__wrapper {margin:auto;width:100%;overflow:hidden;text-align:center;padding:0;background-color:{{ section.settings.bgcolor }};color:{{ section.settings.color }};}
    #shopify-section-{{ section.id }} .footer__wrapper p {color:{{ section.settings.color }};}

    /* content */
    #shopify-section-{{ section.id }} {margin-top:{{ section.settings.spacing_mobile_desktop }}px;margin-bottom:{{ section.settings.spacing_mobile_desktop }}px;}
    #shopify-section-{{ section.id }} .footer__container{position:relative;display:flex;display:-webkit-flex;flex-wrap:wrap;justify-content:space-evenly;margin: auto;padding: 45px 20px 10px;{% if section.settings.max_width != 1500 %}max-width:{{ section.settings.max_width }}px{% endif %};}
    #shopify-section-{{ section.id }} .footer__container a {color:inherit;margin:0}
    #shopify-section-{{ section.id }} .footer__container a:hover{color:{{ btn_color_hover }};opacity:1;text-decoration:underline;}
    #shopify-section-{{ section.id }} .footer__container a:hover svg{fill:{{ btn_color_hover }};}
    #shopify-section-{{ section.id }} .footer__container h4{color:{{ section.settings.title_color }};margin-bottom:0}
    #shopify-section-{{ section.id }} .footer__block .footer__block--content{padding:0;margin:0}
    #shopify-section-{{ section.id }} .footer__logo{width:{{ section.blocks[logo].settings.logo_width_mobile }}px;margin:{{ section.blocks[logo].settings.logo_alignment_mobile }};}
    #shopify-section-{{ section.id }} .footer__logo--text{float:left;text-align:{{ section.blocks[logo].settings.text_alignment_mobile }};margin-top:25px;}
    #shopify-section-{{ section.id }} .footer__social{float:left;margin-top:25px;white-space:nowrap;width:100%;padding:0}
    #shopify-section-{{ section.id }} .footer__social li {list-style-type:none;display:inline-block;margin-right:8px;}
    #shopify-section-{{ section.id }} .footer__social li svg{width:20px;height:auto;fill:{{ section.settings.color }};}
    #shopify-section-{{ section.id }} .footer__block{display:block;text-align:center;flex:1 0 100%;margin-bottom:25px;}
    #shopify-section-{{ section.id }} .footer__block--logo{order:-1;}
    #shopify-section-{{ section.id }} .footer__block--container{display:block;text-align:left}
    #shopify-section-{{ section.id }} .footer__block--title{font-size:1.125em;}
    #shopify-section-{{ section.id }} .footer__block--list{list-style-type:none;margin-bottom:12px}
    #shopify-section-{{ section.id }} .footer__block--link{text-decoration:none;color:inherit}
    #shopify-section-{{ section.id }} .footer__credits{flex: 1 0 100%;order:1;border-top: 1px solid {{ section.settings.color | color_modify: 'alpha', 0.75 }};padding-top:10px;display:flex;display:-webkit-flex;flex-wrap:wrap;align-items:center;justify-content:center;font-size:0.9em}
    #shopify-section-{{ section.id }} .footer__credits--credits {margin:10px 0}
    #shopify-section-{{ section.id }} .footer__credits--credits p{margin:0}
    #shopify-section-{{ section.id }} .footer__credits--mentions{display:flex;display:-webkit-flex;flex-wrap:wrap;justify-content:center;align-items:center;margin:10px 0;padding:0}
    #shopify-section-{{ section.id }} .footer__credits--list {list-style-type:none;margin:0 10px 5px;}
    #shopify-section-{{ section.id }} .footer__payments {display:flex;list-style:none;justify-content:center;padding:0;margin:5px 0 10px}
    #shopify-section-{{ section.id }} .footer__payments li{display:flex}
    #shopify-section-{{ section.id }} .footer__payments svg{width:35px;height:22px;margin-right:5px;}
    #shopify-section-{{ section.id }} .footer__payments li:last-child svg{margin-right:0px}

    /* media queries */
    @media (min-width:{{ breakPoint }}px) {
      #shopify-section-{{ section.id }} {margin-top:{{ section.settings.spacing_top_desktop }}px;margin-bottom:{{ section.settings.spacing_bottom_desktop }}px;}
      #shopify-section-{{ section.id }} .footer__container h4{margin-bottom:1em}
      #shopify-section-{{ section.id }} .footer__block{flex:1 0 186px;margin:0 25px 50px}
      #shopify-section-{{ section.id }} .footer__logo{float:{{ section.blocks[logo].settings.logo_alignment_desk }};width:{{ section.blocks[logo].settings.logo_width_desk }}px;}
      #shopify-section-{{ section.id }} .footer__logo--text{text-align:{{ section.blocks[logo].settings.text_alignment_desk }};}
      #shopify-section-{{ section.id }} .footer__block--container{display:inline-block;}
      #shopify-section-{{ section.id }} .footer__block--logo {flex:1 0 {% if section.blocks[logo].settings.block_width_desk == 0 %}186px{% else %}{{ section.blocks[logo].settings.block_width_desk }}%{% endif %};padding-right:{{ section.blocks[logo].settings.logo_padding_right_desk }}px;}
      #shopify-section-{{ section.id }} .footer__block:not(.footer__block--full) .footer__social{width:100%;text-align:{{ section.blocks[logo].settings.text_alignment_desk }};}
      #shopify-section-{{ section.id }} .footer__credits {max-width:calc(100% - 40px);justify-content:space-between;}
      #shopify-section-{{ section.id }} .footer__credits--list {margin:0 10px}
      #shopify-section-{{ section.id }} .footer__credits.footer__credits--wrapped{justify-content:center;flex-direction:column;margin-bottom:44px}
      #shopify-section-{{ section.id }} .footer__payments {margin:0}
      #shopify-section-{{ section.id }} .footer__credits--wrapped .footer__payments{position:absolute;width:100%;bottom:20px}
      #shopify-section-{{ section.id }} .footer__credits--mentions{margin:10px 40px}
      #shopify-section-{{ section.id }} .footer__block--full {flex:1 0 100%;padding-right:0;display:grid;justify-content: center;}
      #shopify-section-{{ section.id }} .footer__block--full .footer__logo--text{text-align:center}
    }

    @media (max-width:{{ breakPoint | minus: 1}}px) {
      #shopify-section-{{ section.id }} .footer__block h4 {position:relative;padding-right:35px;display:block;cursor:pointer;font-weight:600;line-height:1.5;-webkit-touch-callout: none;user-select: none;-webkit-tap-highlight-color: rgba(0,0,0,0);}
      #shopify-section-{{ section.id }} .footer__block h4:after{width:8px;height:8px;border-right:1px solid {{ section.settings.color }};border-bottom:1px solid {{ section.settings.color }};position:absolute;right:18px;top:25px;content:" ";top:50%;transform:translate(0,-50%) rotate(-45deg);-webkit-transition:all .2s ease-in-out;-moz-transition:all .2s ease-in-out;transition:all .2s ease-in-out}
      #shopify-section-{{ section.id }} .footer__block h4.active:after{transform:translate(0,-75%) rotate(45deg);-webkit-transition:all .2s ease-in-out;-moz-transition:all .2s ease-in-out;transition:all .2s ease-in-out}
      #shopify-section-{{ section.id }} .footer__block .footer__block--content {box-sizing:content-box;overflow:hidden;height:0px;transition:height .4s ease 0.1s;padding-left:20px}
      #shopify-section-{{ section.id }} .footer__block .footer__block--content *:first-child{margin-top:25px}
      #shopify-section-{{ section.id }} .footer__block .footer__block--content li:last-child{margin-bottom:0px}
          #shopify-section-{{ section.id }} .footer__container a, #shopify-section-{{ section.id }} .footer__block .footer__block--content p {font-size:0.95em}
      #shopify-section-{{ section.id }} .footer__block--logo{display: grid;justify-content: center;}
      #shopify-section-{{ section.id }} .footer__credits--credits {width:100%}
    }

    @media (min-width:750px) {
      #shopify-section-footer-maxdesign .footer__block {
        width: 25%;
        max-width: 25%;
    }
    #shopify-section-footer-maxdesign .footer__block--container {
      padding-top: 5px;
      max-width: 75%;
  }
      #shopify-section-footer-maxdesign .footer__block--logo.mob{
        display:none!important;
      }
      #shopify-section-footer-maxdesign .footer__block--logo.desk{display:block}

      #shopify-section-{{ section.id }} .footer__credits {max-width:calc(100% - 40px);justify-content:space-between;}
      #shopify-section-{{ section.id }} .footer__credits--list {margin:0 10px}
      #shopify-section-{{ section.id }} .footer__credits.footer__credits--wrapped{justify-content:center;flex-direction:column;margin-bottom:44px}
      #shopify-section-{{ section.id }} .footer__payments {margin:0}
      #shopify-section-{{ section.id }} .footer__credits--wrapped .footer__payments{position:absolute;width:100%;bottom:20px}
      #shopify-section-{{ section.id }} .footer__credits--mentions{margin:10px 40px}
      #shopify-section-{{ section.id }} .footer__credits--credits {width:auto}
      #shopify-section-footer-maxdesign .footer__block .footer__block--content {padding-left:0px}
      #shopify-section-footer-maxdesign .footer__logo--text {
      float: left;
      text-align: left;
      margin-top: 0px!important;
  }

    }

    @media (max-width:749px) {

      #shopify-section-footer-maxdesign .footer__block--logo.mob{
        display:block;
      }
      #shopify-section-footer-maxdesign .footer__block--logo.desk{display:none!important}

    }

    /* CUSTOM CSS */
    @media (min-width:{{ breakPoint }}px) { {{ section.blocks[developer].settings.css_bureau }} }
    @media (max-width:{{ breakPoint | minus: 1 }}px) { {{ section.blocks[developer].settings.css_mobile }} }
</style>

<footer class="footer__wrapper" role="contentinfo">
  <div class="footer__container">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'logo' %}
          <div class="footer__block footer__block--logo desk">
            {% if block.settings.logo != blank %}
              <h4 class="footer__block--title">
                <img
                  class="footer__logo"
                  src="{{ block.settings.logo | img_url: '800x' }}"
                  alt="{{ block.settings.logo.alt }}"
                >
              </h4>
            {% endif %}
            {% if block.settings.logo_text != blank %}
              <ul class="footer__block--content">
                <li class="footer__block--list">
                  <div class="footer__logo--text">{{ block.settings.logo_text }}</div>
                </li>
              </ul>
            {% endif %}
            {{ social_networks }}
          </div>
{% when 'menu' %}
          {% assign current_lang = localization.language.iso_code %}
          {% assign menu_to_use = block.settings.link_list %}
          {% if current_lang == 'en' and block.settings.menu_en != blank %}
            {% assign menu_to_use = block.settings.menu_en %}
          {% elsif current_lang == 'nl' and block.settings.menu_nl != blank %}
            {% assign menu_to_use = block.settings.menu_nl %}
          {% elsif current_lang == 'sv' and block.settings.menu_sv != blank %}
            {% assign menu_to_use = block.settings.menu_sv %}
          {% elsif current_lang == 'es' and block.settings.menu_es != blank %}
            {% assign menu_to_use = block.settings.menu_es %}
          {% elsif current_lang == 'de' and block.settings.menu_de != blank %}
            {% assign menu_to_use = block.settings.menu_de %}
          {% endif %}
          <div class="footer__block">
            {% if linklists[menu_to_use].links.size > 0 %}
              <div class="footer__block--container">
                <h4 class="footer__block--title">{{ linklists[menu_to_use].title }}</h4>
                <ul class="footer__block--content">
                  {% for link in linklists[menu_to_use].links %}
                    <li class="footer__block--list">
                      <a href="{{ link.url }}" class="footer__block--link">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          </div>
        {% when 'text' %}
          <div class="footer__block">
            <div class="footer__block--container">
              <h4 class="footer__block--title">{{ block.settings.title | escape }}</h4>
              <div class="footer__block--content">{{ block.settings.text }}</div>
            </div>
          </div>
        {% when 'credits' %}
          <div class="footer__credits">
            <div class="footer__credits--credits">{{ block.settings.credits }}</div>
            {% if linklists[block.settings.link_list].links.size > 0 %}
              <ul class="footer__credits--mentions footer__block--content">
                {% for link in linklists[block.settings.link_list].links %}
                  <li class="footer__credits--list">
                    <a href="{{ link.url }}" class="footer__credits--link">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
            {%- unless shop.enabled_payment_types == empty -%}
              <ul class="footer__payments">
                {%- for type in shop.enabled_payment_types -%}
                  <li>
                    {{ type | payment_type_svg_tag }}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endunless -%}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</footer>

<script> 
  function init_{{ section.id | remove: '-' }}() {
    let flag = true, blockBP = false;
    function footerInit() {
      if(window.matchMedia("(max-width:{{ breakPoint | minus: 1 }}px)").matches && flag) {
        flag = false;
        let tabs = document.querySelectorAll('.footer__block h4')
        tabs.forEach(tab => {
          tab.addEventListener('click', function(e) {
            console.log(tab.classList);
            tab.classList.toggle('active')
            if (tab.classList.contains('active')) {
              //hide other tabs
              tabs.forEach(tab => {
                if (tab != e.target) {
                  tab.classList.remove('active');
                  tab.nextElementSibling.style.height = '0px';
                }
              })
              var tabContent = tab.nextElementSibling;
              tabContent.style.height = 'auto';
              var tabHeight = tabContent.offsetHeight + 'px'
              tabContent.style.height = '0px';
              setTimeout(function() {tabContent.style.height = tabHeight}, 15)
            } else {
              tab.classList.remove('active');
              tab.nextElementSibling.style.height = '0px';
            }
          })
        })
      }
      if(window.matchMedia("(min-width:750px)").matches) {
        //credits layout
        let payments = document.querySelector('.footer__payments')
        let mentions = document.querySelector('.footer__credits--mentions')
        if(mentions) {
          if (payments.offsetTop - mentions.offsetTop > 20) {
            mentions.parentElement.classList.add('footer__credits--wrapped')
          } else {
            mentions.parentElement.classList.remove('footer__credits--wrapped')
          }
        }
        //blocks layout
        let firstBlock = document.querySelector('.footer__block:first-child'), lastBlock = document.querySelector('.footer__block:nth-child(4)');
        if (lastBlock.offsetTop - firstBlock.offsetTop > 20 && blockBP == false) {
          if(!blockBP) {blockBP = window.screen.width;console.log(blockBP)}
          
          firstBlock.classList.add('footer__block--full')
        } else if (window.matchMedia(`(min-width:${blockBP}px)`).matches) {
          firstBlock.classList.remove('footer__block--full');
          blockBP = false;
        }
      }
    }
    footerInit()
    document.addEventListener('shopify:section:select', footerInit)
    window.addEventListener('resize', footerInit)
  }
  init_{{ section.id | remove: '-' }}()
</script>

