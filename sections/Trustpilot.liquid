<div class="mob-review-image setMargin">
  <div class="rate_first only_rate">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/onlystar_134x134_crop_center@2x.png?v=1603347103">
    <h2 style="color:#303030; text-transform: initial;">{{ section.settings.review_title }}</h2>
  </div>
  <div class="rate_first">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/fullstar_134x134_crop_center@2x.png?v=1603347111">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/fullstar_134x134_crop_center@2x.png?v=1603347111">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/fullstar_134x134_crop_center@2x.png?v=1603347111">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/fullstar_134x134_crop_center@2x.png?v=1603347111">
    <img src="https://cdn.shopify.com/s/files/1/0494/6798/1992/files/half-star_134x134_crop_center@2x.png?v=1603347108">
  </div>
  <div class="avarage_rate" style="margin-bottom:20px;">
    <p style="font-family: Montserrat, sans-serif; font-weight: 500;">
      {{ section.settings.rate }}/5 {{ section.settings.total_review_title }}
    </p>
  </div>
</div>
{% schema %}
  {
    "name": "TrustPilot",
    "class": "index-section",
	"settings": [
      {
        "type": "text",
        "id": "review_title",
        "label": "Review Title",
        "default": "Trustpilot"
      },
	{
        "type": "text",
        "id": "total_review_title",
        "label": "Total Review Title",
        "default": "Comentarios Verificados"
      },
	  {
         "type": "text",
         "id": "rate",
         "label": "Rate",
         "default": "4,5"
      }
],
    "presets": [
    {
      "name": "Trustpilot",

    }
  ]
  }
{% endschema %}

{% stylesheet %}
  /* Review trust pilot */

  .trust_icons {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      margin: 0;
      padding: 0;
      margin-bottom: 10px;
  }

  .trust_icons li {
      display: flex;
      align-items: center;
      flex-direction: column;
      flex: 1;
      text-align: center;
      font-size: 11px;
      line-height: 16px;
  }

  .trust_icons li svg {
      display: block;
      width: 35px;
      height: 35px;
      margin: 0 0 10px;
  }
  .cv__contents_reviews_main {
      border: 1px solid #fff;
          border-top-color: rgb(255, 255, 255);
          border-top-style: solid;
          border-top-width: 1px;
      border-radius: 0 0 10px 10px;
      padding: 15px 0 15px 0;
      border-top: 0;
      background-color: #fff;
  }.cv__contents_reviews {
      max-height: 330px;
      overflow-y: auto;
      padding: 0 15px;
  }.cv_custom_second_heading
  {    display: flex;
  }.cv_content_first_part .cv__img_reviews {
         width: 100%;
      height: 300px;
      object-fit: cover;
      object-position: top;
  }.cv_custom_main_heading {
      text-align: center;
      margin: 50px 0px 20px;
  }.mob-review-image {
      text-align: center;
  }.rate_first img {
      width: 65px;
      margin: 2px;
  }
  .review_slider
  {
        padding-left: 30px;overflow: hidden;
  }.review_slider .slick-slide{
        padding: 3px;
  }.cv_custom_main_heading {
      text-align: center;
      margin:0px 0px 20px;
  }.cv_custom_main_heading h2, .cv_custom_main_heading .h2 {
      margin-bottom: 0px;
      padding-top: 40px;
  }
  .cv_custom_second_heading img {
          width: 35px;
      margin-left: 3px;
      max-width: 190px;
      margin-bottom: 10px;
  }.cv_custom_heading_title h3 {
      margin-bottom: 10px;
      font-size: 18px;
      font-weight: bold;
      color: #000000;
  }.cv_custom_main_paragraph_reviews p {
      font-size: 12px;
      line-height: 20px;
  }.rate_first {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 7px 0px;
  }
  .only_rate
  {
    padding-top: 60px;
  }
  .cv_custom_main_content_reviews_outer .slick-dots
  {
        bottom: -50px;
  }

  .cv_custom_main_wrapper_reviews:hover .slick-prev {
      -webkit-transform: translateX(0%);
      -moz-transform: translateX(0%);
      -ms-transform: translateX(0%);
      -o-transform: translateX(0%);
      transform: translateX(0%);
      opacity: 0.8;
  }.cv_custom_main_wrapper_reviews:hover .slick-next {
      -webkit-transform: translateX(0%);
      -moz-transform: translateX(0%);
      -ms-transform: translateX(0%);
      -o-transform: translateX(0%);
      transform: translateX(0%);
      opacity: 0.8;
  }.cv_custom_main_wrapper_reviews .slick-next:hover{    background: #eaeaea url(https://cdn.shopify.com/s/files/1/0280/5910/7380/files/next.png?v=1590728977) no-repeat center center;background-size: auto;
      background-size: 20px 20px;
  }.cv_custom_main_wrapper_reviews .slick-prev:hover{background: #eaeaea url(https://cdn.shopify.com/s/files/1/0280/5910/7380/files/prev.png?v=1590729126) no-repeat center center;background-size: auto;
      background-size: 20px 20px;
  }
  .slick-arrow {
      position: absolute;
      display: -ms-flexbox;
      display: flex;
      -ms-flex-align: center;
      align-items: center;
      -ms-flex-pack: center;
      justify-content: center;
      line-height: 0px;
      font-size: 0px;
      cursor: pointer;
      background: #fff;
      color: #fff;
      top: 50%;
      transform: translate(0, -50%);
      padding: 0;
      border: none;
      opacity: 1;
      overflow: hidden;
      border-radius: 50%;
      z-index: 1;
      box-shadow: -1px 2px 10px 0 rgba(123,123,123,0.2);
  }.cv_custom_main_wrapper_reviews .slick-prev svg, .cv_custom_main_wrapper_reviews .slick-next svg {
      display: none;
  }.cv_custom_main_wrapper_reviews .slick-prev {
      -moz-transition: all 0.5s;
      -webkit-transition: all 0.5s;
      transition: all 0.5s;
      position: absolute;
      top: 50%;
      margin: 0px;
          margin-top: 0px;
      padding: 0px;
      background: none;
      text-indent: -9999px;
      width: 60px !important;
      height: 60px !important;
      margin-top: -30px !important;
      cursor: pointer;
      background: #eaeaea url(https://cdn.shopify.com/s/files/1/0280/5910/7380/files/prev.png?v=1590729126) no-repeat center center;
          background-size: auto;
      background-size: 20px 20px;
      -webkit-transform: translateX(-100%);
      -moz-transform: translateX(-100%);
      -ms-transform: translateX(-100%);
      -o-transform: translateX(-100%);
      transform: translateX(-100%);
      background-size: 20px 20px;
      left: 10px;
      opacity: 0;
      border-radius: 50px;
  }.cv_custom_main_wrapper_reviews .slick-next {
      -moz-transition: all 0.5s;
      -webkit-transition: all 0.5s;
      transition: all 0.5s;
      position: absolute;
      top: 50%;
      margin: 0px;
          margin-top: 0px;
      padding: 0px;
      background: none;
      text-indent: -9999px;
      width: 60px !important;
      height: 60px !important;
      margin-top: -30px !important;
      cursor: pointer;
      background: #eaeaea url(https://cdn.shopify.com/s/files/1/0280/5910/7380/files/next.png?v=1590728977) no-repeat center center;
          background-size: auto;
      background-size: 20px 20px;
      -webkit-transform: translateX(100%);
      -moz-transform: translateX(100%);
      -ms-transform: translateX(100%);
      -o-transform: translateX(100%);
      transform: translateX(100%);
      opacity: 0;
      right: 10px;
  }
  .slick-initialized .slick-slide {
      display: none;
  }
  .cv__line {
      display: inline-block;
      width: 100px;
      height: 3px;
      background-color: #5BC1AB;
  }
  .cv_custom_main_heading h2{
  	    margin: 50px 0 0;
  }.rate_first h2, .rate_first .h2 {
      margin: 0;
      font-size: 40px;
      font-weight: 600;
      font-family: inherit;
  }
  .review_slider .slick-slider .slick-dots li button::before{
    font-size: 16px;
      content: '•';
      color: #000;
      opacity: .15;
  }
  .review_slider .slick-slider .slick-dots li.slick-active button::before{
      opacity: .5;
  }
  .top_banner_slider {
      color: #FFF;
      display: none;
  }

  .cv_sales_repeated.slick-slide {
      color: #FFF;
     // display: flex !important;
      align-items: center;
      justify-content: center;
  }
  .slider_outer{
    display: flex !important;
      align-items: center;
      justify-content: center;
  }
  .cv__saleContent-text {
      color: #000;
  }
  .cv__saleIcon-svg {
      display: flex;
      align-items: center;
        justify-content: center;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  @media only screen and (max-width: 768px) {
    .cv_custom_main_heading .h2, .cv_custom_main_heading h2 {
      margin-bottom: 0;
      padding-top: 0;
  }
  	.review_slider { padding-left: 0px; overflow: hidden; }
    .cv_custom_second_heading img { width: 25px; height: 25px; }
    .rate_first img { width: 35px; }
    .review_slider .slick-dotted.slick-slider { padding-left: 22px; }
    .cv_custom_main_wrapper_reviews .slick-next { transform: translateX(0px); opacity: 0.8; width: 45px !important; height: 45px !important; }
    .cv_custom_main_wrapper_reviews .slick-prev { transform: translateX(0px); opacity: 0.8; left: 30px; width: 45px !important; height: 45px !important; }
    .cv_custom_main_wrapper_reviews .slick-arrow { top: 43% !important; }.cv_content_first_part .cv__img_reviews {
      height: 200px;
  }
   .setMargin {
  	margin-top:0px;
  }
  }

  @media only screen and (min-width: 767px) {
   .setMargin{
  	margin-top:-100px;
  }

  }
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
