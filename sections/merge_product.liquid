document.querySelectorAll('.js-bundle-qty-container').forEach(container => {
  const input = container.querySelector('.js-bundle-qty-value');
  const block = container.closest('.packsUpsell-block');

  container.addEventListener('click', (e) => {
  const btn = e.target.closest('button');
  if (!btn) return;

  let val = parseInt(input.value);
  if (btn.classList.contains('js-bundle-qty-increment') && val < 3) val++;
  else if (btn.classList.contains('js-bundle-qty-decrement') && val > 1) val--;

  input.value = val;
  
  // Toggle Row Visibility (instead of just dropdowns)
  block.querySelectorAll('.js-bundle-variant-row').forEach((row, i) => {
    if (i < val) {
