<script>
                (function() {
                  function updateDateText() {
                    const dateEl = document.getElementById('start_date_{{ section.id }}');
                    if (!dateEl) return;

                    const gap = parseInt(dateEl.dataset.date) || 0;
                    
                    let locale = 'en';
                    if (typeof Weglot !== 'undefined' && typeof Weglot.getCurrentLang === 'function') {
                      locale = Weglot.getCurrentLang().substring(0, 2).toLowerCase();
                    } else if (document.documentElement.lang) {
                      locale = document.documentElement.lang.split('-')[0].toLowerCase();
                    } else if (window.Shopify && window.Shopify.locale) {
                      locale = window.Shopify.locale.split('-')[0].toLowerCase();
                    } else if (dateEl.dataset.locale) {
                      locale = dateEl.dataset.locale.split('-')[0].toLowerCase();
                    }
                    
                    const startDate = new Date();
                    startDate.setDate(startDate.getDate() + gap);
                    
                    const endDate = new Date(startDate);
                    endDate.setDate(endDate.getDate()+2); // 2-day dispatch range

                    const monthMap = {
                      en: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                      fr: ['janv.', 'févr.', 'mars', 'avr.', 'mai', 'juin', 'juil.', 'août', 'sept.', 'oct.', 'nov.', 'déc.'],
                      nl: ['jan.', 'feb.', 'mrt.', 'apr.', 'mei', 'jun.', 'jul.', 'aug.', 'sep.', 'okt.', 'nov.', 'dec.'],
                      de: ['Jan.', 'Feb.', 'März', 'Apr.', 'Mai', 'Juni', 'Juli', 'Aug.', 'Sept.', 'Okt.', 'Nov.', 'Dez.'],
                      es: ['ene.', 'feb.', 'mar.', 'abr.', 'may.', 'jun.', 'jul.', 'ago.', 'sept.', 'oct.', 'nov.', 'dic.'],
                      it: ['gen', 'feb', 'mar', 'apr', 'mag', 'giu', 'lug', 'ago', 'set', 'ott', 'nov', 'dic']
                    };
                    
                    const months = monthMap[locale] || monthMap['en'];

                    const startDay = startDate.getDate();
                    const startMonth = months[startDate.getMonth()];
                    
                    const endDay = endDate.getDate();
                    const endMonth = months[endDate.getMonth()];

                    if (startDate.getMonth() === endDate.getMonth()) {
                      dateEl.textContent = `${startDay} - ${endDay} ${startMonth}`;
                    } else {
                      dateEl.textContent = `${startDay} ${startMonth} - ${endDay} ${endMonth}`;
                    }
                  }
                  
                  updateDateText();
                  setTimeout(updateDateText, 1000);
                  setTimeout(updateDateText, 3000);
                })();
              </script>
