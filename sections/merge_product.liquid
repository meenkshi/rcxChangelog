}
else if (window.location.pathname.includes('/sv')) {
  subfolder = '/sv-se/cart';
  localePrefix = '/sv';
}
              
              if (action !== 'cart') {
                const permalinkItems = itemsToAdd.map(item => item.id + ':' + item.quantity).join(',');
                window.location.href = localePrefix + '/cart/' + permalinkItems;
                return;
              }

              fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: itemsToAdd })
              })
              .then(response => response.json())
