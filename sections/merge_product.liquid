function updateCalculatedPrices(block) {
  const visibleDropdowns = block.querySelectorAll('.js-bundle-variant-row.is-visible .js-bundle-variant-dropdown');
  let total = 0;
  let totalCompare = 0;
  
  // Frequency Map for Variant IDs to update master selector (for Buy Now button)
  const idFrequency = {};
  let mostFrequentId = null;
  let maxFreq = 0;
  let firstId = null;

  visibleDropdowns.forEach((dd, idx) => {
    const val = dd.value;
    if (idx === 0) firstId = val;
    idFrequency[val] = (idFrequency[val] || 0) + 1;
    if (idFrequency[val] > maxFreq) {
      maxFreq = idFrequency[val];
      mostFrequentId = val;
    }

    const selected = dd.options[dd.selectedIndex];
    if (selected) {
      // Retrieve values in cents from data attributes, ensuring safe integer parsing
      const unitPrice = parseInt(selected.getAttribute('data-unit-price') || 0);
      const unitCompare = parseInt(selected.getAttribute('data-unit-compare') || selected.getAttribute('data-unit-price') || 0);
      total += unitPrice;
      totalCompare += unitCompare;
    }
  });
  
  // If tied or single, mostFrequentId holds the winner based on first occurrence
  if (!mostFrequentId) mostFrequentId = firstId;

  // Format prices using the Shop's money format helper
const formattedPrice = formatMoney(total, shopMoneyFormat);
  const formattedCompare = formatMoney(totalCompare, shopMoneyFormat);
  const savings = totalCompare > total ? Math.round(((totalCompare - total) / totalCompare) * 100) : 0;
  const formattedDiff = totalCompare > total ? formatMoney(totalCompare - total, shopMoneyFormat) : '';

  // 1. Sync local block labels (Visual text inside the pack)
  const priceLabel = block.querySelector('span[data-variant-price]');
  if (priceLabel) priceLabel.textContent = formattedPrice;

  const compareLabel = block.querySelector('span[data-variant-compare-price]');
  if (compareLabel) {
    compareLabel.textContent = formattedCompare;
    compareLabel.style.display = (totalCompare <= total) ? 'none' : '';
  }

// 2. Update radio input attributes (For form submission logic and MutationObserver)
  const radio = block.querySelector('input[name="pack-upsell"]');
  if (radio) {
    radio.setAttribute('data-variant-price', formattedPrice);
    radio.setAttribute('data-variant-compare-price', formattedCompare);
    radio.setAttribute('data-variant-savings', savings);
    radio.setAttribute('data-variant-formatted-diff', formattedDiff);
  }

  // 3. Sync theme-level global selectors if this specific block is currently selected
  if (block.classList.contains('active')) {
    const mainPriceSelector = '{{ section.blocks[developer].settings.selector_price }}';
    const mainCompareSelector = '{{ section.blocks[developer].settings.selector_compare_price }}';

    if (mainPriceSelector !== 'NA') {
      document.querySelectorAll(mainPriceSelector).forEach(el => el.innerHTML = formattedPrice);
    }
    if (mainCompareSelector !== 'NA' && mainCompareSelector !== '') {
      document.querySelectorAll(mainCompareSelector).forEach(el => {
        el.innerHTML = formattedCompare;
        el.style.display = (totalCompare <= total) ? 'none' : '';
      });
    }

    // Handle specific legacy IDs found in this template
    const testPrice = document.getElementById('testprice');
    const testPriceOld = document.getElementById('testpriceold');
    if (testPrice) testPrice.innerHTML = formattedPrice;
    if (testPriceOld) testPriceOld.innerHTML = formattedCompare;

    // Update masterSelector for Buy Now with frequency logic
    if (masterSelector && mostFrequentId) {
      masterSelector.value = mostFrequentId;
      masterSelector.dispatchEvent(new Event('change'));
    }

    // 4. Trigger MutationObserver to refresh Save Badges and dynamic UI elements
    if (radio) {
      radio.setAttribute('data-active', 'false');
      radio.setAttribute('data-active', 'true');
    }
  }
}
      {%- if virtual_stocks -%}
      //define product handles and stock arrays
      let decrement, vStocksDefault, vStocksTrue, vStocksDefaultMin, vStocksDefaultMax, evalDecrement;
      let variantsID = [{{ variants_id_1 | default: '[]' }}, {{ variants_id_2 | default: '[]' }}, {{ variants_id_3 | default: '[]' }}];
      let vStocks = [{{ virtual_stocks_1 | default: '[]' }}, {{ virtual_stocks_2 | default: '[]' }}, {{ virtual_stocks_3 | default: '[]' }}];
      let masterDict = {
        variantsID: [variantsID[0], variantsID[1], variantsID[2]],
        vStocks: [vStocks[0], vStocks[1], vStocks[2]]
      }
      let vStocksVisits = {{ virtual_stocks_visits | default: false }}
      let pageLoad = true
      
      //fetch Dict in storage if it exist
      masterDict = localStorage.getItem("vStocks") !== null && vStocksVisits ? JSON.parse(localStorage.getItem("vStocks")) : masterDict   
      
      function vStocksDecrement(newVisit, valueToDecrement) {
        if(!vStocksVisits && newVisit) {
          let currentDate = new Date()
          let timeToday = (currentDate.getTime() - currentDate.setHours({{ section.settings.virtual_stocks_start }},0,0,0))/1000/60/60/24
          let timeTodayMin = timeToday < 0 ? 0 : timeToday
          let decrement = Math.round(valueToDecrement*timeTodayMin)
          return decrement; 
        } else if(newVisit && ("time" in masterDict)) {
          //check last time it was updated
          let timeTreshold = {{ section.settings.virtual_stocks_interval }}
          let timeDiff = +new Date - masterDict.time
          let timeDiffMns = Math.floor(timeDiff / 1000)
          if(timeDiffMns >= timeTreshold) {
            return Math.floor(Math.random() * 2) + 1;
          } else {
            return 0;
          }
        } else {
          return 0;
        }
      }
	 
      //push new key/values in Dict if they don't exist
      function isArrayInArray(x, check) {var result = x.find(function(ele) {return (JSON.stringify(ele) === JSON.stringify(check))});return result !=null}
      for (var i = 0, n = variantsID.length; i < n; i++) {if(!isArrayInArray(masterDict.variantsID, variantsID[i])){masterDict.variantsID.push(variantsID[i]);masterDict.vStocks.push(vStocks[i])}}
      
      //decrement virtual stock in Dom & update storage
      function getVirtualStocks(packID, inventoryNode, newVisit, packIndex) {
        let firstVariant = newVisit ? true : false;
        //loop through all set of product variants
        for (var i = 0, m = masterDict.variantsID.length; i < m; i++) {
          let variantsID = masterDict.variantsID[i]
          let packIDinVariantsID = variantsID.includes(+packID)
		  //loop through current product variants  
          for (var j = 0, v = variantsID.length; j < v; j++) {
            //decrement variant max vStocks
            vStocksDefault = masterDict.vStocks[i][j]
            vStocksTrue = vStocksDefault.includes('-')
            vStocksDefaultMin = vStocksTrue ? +vStocksDefault.split('-')[0] : vStocksDefault
            vStocksDefaultMax = vStocksTrue ? +vStocksDefault.split('-')[1] - vStocksDecrement(newVisit, +vStocksDefault.split('-')[1]) : vStocksDefault
            //if vStocks can be decremented on newVisit & enabled & packID belongs to array of variants
            if(vStocksDefaultMax >= vStocksDefaultMin && vStocksTrue && packIDinVariantsID) {
              //write first vstock value on load
              if(newVisit && firstVariant) {
                console.log(vStocksDefaultMax);
                if(inventoryNode) {inventoryNode.textContent = vStocksDefaultMax;}firstVariant=false;
                /*cc*/if(document.querySelector('.product_left_counter') && pageLoad) {pageLoad = false;document.querySelector('.product_left_counter').textContent = vStocksDefaultMax}
              } 
              //else if variant change & updated packID matches array value  
              else if(!newVisit && !firstVariant && variantsID[j] == packID) {
                if(inventoryNode) {inventoryNode.textContent = vStocksDefaultMax;}
                /*cc*/if(document.querySelector('.product_left_counter')) {console.log('22');document.querySelector('.product_left_counter').textContent = vStocksDefaultMax}
              }
              //update Dict vStocks forEach variant on newVisit
