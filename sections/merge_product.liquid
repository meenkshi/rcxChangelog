{% for block in section.blocks %}
  {% assign block_product_id = block.settings.product_id | plus: 0 %}
  {% if block_product_id == product.id %}
    {% assign index = forloop.index0 %}
  {% elsif block.type == 'developer' %}
    {% assign developer = forloop.index0 %}
  {% endif %}
{% endfor %}

{% if section.blocks[index].settings.enable %}
  {% comment %}DISPLAY MODE & SETTINGS{% endcomment %}
  {% assign mode_desktop = section.settings.mode_desktop %}
  {% assign mode_mobile = section.settings.mode_mobile %}
  {% assign fill_mode = section.settings.fill_action %}
  {% assign radius = section.settings.border_radius | append: 'px' %}
  {% assign font_size_desktop = section.settings.font_size_desktop | divided_by: 100.0 | plus: 1 %}
  {% assign font_size_mobile = section.settings.font_size_mobile | divided_by: 100.0 | plus: 1 %}
  {% capture breakPoint %}{% if developer != nil %}{{ section.blocks[developer].settings.query }}{% else %}1000{% endif %}{% endcapture -%}
  {%- assign breakPoint = breakPoint | plus: 0 %}
  {% if section.blocks[index].settings.description_enable_1 %}{% assign show_description_1 = true %}{% endif %}
  {% if section.blocks[index].settings.description_enable_2 %}{% assign show_description_2 = true %}{% endif %}
  {% if section.blocks[index].settings.description_enable_3 %}{% assign show_description_3 = true %}{% endif %}
  {% if section.blocks[index].settings.properties_enable_1 %}{% assign show_properties_1 = true %}{% endif %}
  {% if section.blocks[index].settings.properties_enable_2 %}{% assign show_properties_2 = true %}{% endif %}
  {% if section.blocks[index].settings.properties_enable_3 %}{% assign show_properties_3 = true %}{% endif %}
  {% if section.blocks[index].settings.variants_enable_1 %}{% assign show_variants_1 = true %}{% endif %}
  {% if section.blocks[index].settings.variants_enable_2 %}{% assign show_variants_2 = true %}{% endif %}
  {% if section.blocks[index].settings.variants_enable_3 %}{% assign show_variants_3 = true %}{% endif %}
  {% if section.blocks[index].settings.virtual_stocks %}{% assign virtual_stocks = true %}{% endif %}
  {% if section.settings.virtual_stocks_type == 'visits' %}{% assign virtual_stocks_visits = true %}{% endif %}
{% endif %}

  <style>
    .product-save-badge {
  display: inline-flex;
  align-items: center;
  vertical-align: middle;
  white-space: nowrap;
  margin-right: 8px;
  position: relative !important;
  float: none !important;
  background-color: {{ section.settings.save_badge_bg_color }};
  color: {{ section.settings.save_badge_text_color }};
  padding: 5px 12px;
  border-radius: 100px;
  font-weight: 700;
  font-size: 11px;
  margin-top: 10px;
}
.bundle-qty-row {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  margin-top: 5px;
  padding-top: 8px;
  
  width: 100%; /* Added to ensure full width */
}
.bundle-variant-row {
  display: none;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
  width: 100%;
}

.bundle-variant-row.is-visible {
  display: flex;
}

.bundle-variant-img {
  display: none;
  width: 44px;
  height: 44px;
  border-radius: 4px;
  object-fit: cover;
  border: 1px solid #e2e2e2;
  flex: 0 0 44px;
}

.bundle-qty-row__column--left {
  flex: 0 0 110px;
}

.bundle-qty-row__column--right {
  flex: 1;
}

.bundle-qty-row__label {
  display: block;
  font-weight: 700;
  font-size: 13px;
  margin-bottom: 8px;
  color: #333;
}

.bundle-qty-control {
  display: flex;
  align-items: center;
  border: 1px solid #e2e2e2;
  border-radius: 100px;
  overflow: hidden;
  background: #fff;
  height: 42px;
}

.bundle-qty-control__btn {
  flex: 1;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 18px;
  font-weight: 300;
  padding: 0;
  transition: background 0.2s;
}

.bundle-qty-control__btn:hover {
  background: #f9f9f9;
}

.bundle-qty-control__input {
  width: 32px;
  text-align: center;
  border: none;
  font-size: 16px;
  font-weight: 700;
  pointer-events: none;
  padding: 0;
}

.bundle-variant-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.bundle-variant-select {
  width: 100%;
  height: 44px;
  border-radius: 8px;
  border: 1px solid #e2e2e2;
  padding: 0 12px;
  font-size: 14px;
  background-color: #fff;
  /* Removed display:none, handled by row parent */
  flex: 1;
}

.bundle-variant-select.is-visible {
  display: block;
}

.bundle-extra-gifts {
  padding: 16px;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  line-height: 1.2;
}

.bundle-extra-gifts__item {
  display: flex;
  align-items: center;
  gap: 12px;
}

.bundle-extra-gifts__image {
  width: 44px;
  height: 44px;
  border-radius: 4px;
  object-fit: cover;
  flex-shrink: 0;
  background: #fff;
}

.bundle-extra-gifts__title {
  flex: 1;
 font-weight:400;
}
.bundle-extra-gifts__title_v1{
  flex: 1;
  font-weight:700;
}

.bundle-extra-gifts__price {
  text-decoration: line-through;
  opacity: 0.6;
}

/* ATC Loading Dots */
.product-form__cart-submit .loading-dots {
  display: none;
  justify-content: center;
  align-items: center;
  gap: 4px;
}

.product-form__cart-submit .loading-dots span {
  width: 8px;
  height: 8px;
  background-color: currentColor;
  border-radius: 50%;
  display: inline-block;
  animation: loading-pulse 1.4s infinite ease-in-out both;
}

.product-form__cart-submit .loading-dots span:nth-child(1) { animation-delay: -0.32s; }
.product-form__cart-submit .loading-dots span:nth-child(2) { animation-delay: -0.16s; }

@keyframes loading-pulse {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

.product-form__cart-submit.is-loading [data-add-to-cart-text] {
  display: none;
}

.product-form__cart-submit.is-loading .loading-dots {
  display: flex;
}
    /* mega container styles & fixes */
    #shopify-section-{{ section.id }}{width:100%}
    #packsUpsell{max-width:590px;margin-top:{{ section.settings.spacing_top_desktop }}px;margin-bottom:{{ section.settings.spacing_bottom_desktop }}px;}
    #shopify-section-{{ section.id }} label {text-transform:none}
    {% if section.settings.main_price_disable %}{{ section.blocks[developer].settings.selector_price }}, {{ section.blocks[developer].settings.selector_compare_price }} {display:none;height:0px;overflow:hidden}{% endif %}

    /* upsell label container */
    .packsUpsell-label{color:{{ section.blocks[index].settings.text_upsell_color }};fill:{{ section.blocks[index].settings.text_upsell_color }};font-style:normal;display:flex;display:-webkit-flex;justify-content:center;align-items:center;width:100%;padding:0 0 10px;font-weight:600;font-size:1.1em;text-align:center}

    /* upsell blocks container + content*/
    {% unless section.settings.color_bg contains 'rgba(0,0,0,0)' %}.packsUpsell-tabs {background-color:{{ section.settings.color_bg }};padding:15px;border-radius:25px;}{% endunless %}
    .packsUpsell-tabs .packsUpsell-block:first-child {margin-top:0}
    .packsUpsell-block{position:relative;margin-top:10px;font-size:{{ font_size_desktop }}em;border-radius:{{ radius }};background:{{ section.settings.color_upsell }};-webkit-touch-callout: none;-webkit-user-select: none;-moz-user-select: none;-ms-user-select: none;user-select: none;-webkit-tap-highlight-color: rgba(0,0,0,0)}
.packsUpsell-block > label{position:relative;font-style:normal;display:flex;align-items:center;cursor:pointer;margin:0;padding:10px;font-size:1em;border-radius:{{ radius }};transition: none;min-height: 76px; box-sizing: border-box;}
    .packsUpsell-block > label > * { pointer-events:none} /*ios*/
    .packsUpsell-block:not(.active) {box-shadow: inset 0px 0px 0 1px {{ section.settings.color_border }};}
    .packsUpsell-input {margin-right: 10px;}
.packsUpsell-info {display:flex;flex-direction:column;justify-content:space-around;align-items:start;text-align:left}
    .packsUpsell-info {margin-left:10px}{% if section.settings.img_enable_desktop %}{% endif %}
    .packsUpsell-info > * {margin-bottom:3px}
    .packsUpsell-image{margin-right:10px;min-height:60px;align-items: center;display:none;}
    .packsUpsell-image span{border-radius:{{ section.settings.border_radius_images }}px;display:inline-block;width:60px;height:60px;padding:0px;margin:5px;background-size:cover;background-repeat:no-repeat}
    .packsUpsell-title{font-weight:600;font-size:1.1em;display:inline-block;color:{{ section.settings.color_title }};text-transform:none;}
    .packsUpsell-price{font-size:1em;font-weight:400;color:{{ section.settings.color_price }};}
    .packsUpsell-comparePrice{color:{{ section.settings.color_compare_price }};padding-right: 5px;display: inline-block;text-decoration: line-through;font-weight:300}
    .packsUpsell-line1{font-size:0.95em;color:{{ section.settings.color_flash_text }};font-weight:600;}
    .packsUpsell-line1.packsUpsell-line1--blink{animation:blink 1.4s ease-in-out infinite;animation-duration: 0.8s;animation-direction: alternate;-webkit-animation-duration: 0.8s;-webkit-animation-direction:alternate;}
    .packsUpsell-line2{font-size:1em;font-weight:600;color:{{ section.settings.color_customtext }};}

    /* radio button checked + not checked */
    .packsUpsell-input { display:{% unless section.settings.radio_enable_desktop %}none{% else %}block{% endunless %};}
    .packsUpsell-input [type="radio"]:checked + span:after, .packsUpsell-input [type="radio"]:not(:checked) + span:after {content:'';width:12px;height:12px;background:{{ section.settings.color_upsell }};position:absolute;top:-11px;left:3px;border-radius:100%;-webkit-transition:all 0.2s ease;transition:all 0.2s ease;}
    /* radio button cheked only */
    .packsUpsell-input [type="radio"]:checked{position:absolute;left:-9999px;}
    .packsUpsell-input [type="radio"]:checked + span{position:relative;padding-left:18px;cursor:pointer;line-height:20px;display:inline-block;color:#000;}
    .packsUpsell-input [type="radio"]:checked + span:before{content:'';position:absolute;left:0;top:-14px;width:18px;height:18px;border:1px solid #ddd;border-radius:100%;background:#fff;}
    .packsUpsell-input [type="radio"]:checked + span:after{content:'';width:12px;height:12px;background:{{ section.settings.color_upsell_active | color_darken: 7 }};position:absolute;top:-11px;left:3px;border-radius:100%;-webkit-transition:all 0.2s ease;transition:all 0.2s ease;opacity:1;-webkit-transform:scale(1);transform:scale(1);}
    /* radio button not checked only */
    .packsUpsell-input [type="radio"]:not(:checked) {position: absolute;left: -9999px;}
    .packsUpsell-input [type="radio"]:not(:checked) + span {position: relative;padding-left: 18px;cursor: pointer;line-height: 20px;display: inline-block;color: #000;}
    .packsUpsell-input [type="radio"]:not(:checked) + span:before {content: '';position: absolute;left: 0;top: -14px;width: 18px;height: 18px;border: 1px solid #ddd;border-radius: 100%;background: #fff;}
    .packsUpsell-input [type="radio"]:not(:checked) + span:after {opacity: 0;transform: scale(0);}

    /* upsell keyframes */
    @keyframes blink{0%{opacity:1} 100%{opacity:0.2}}
    @-webkit-keyframes blink{0%{opacity:1} 100%{opacity:0.2}}

    /* display mode with price display on the right side */
    {% if mode_desktop == 'original' %}
    @media (min-width: {{ breakPoint }}px){
      .packsUpsell-price {position: absolute;right: 0;display: flex;align-items: flex-end;justify-content: center;flex-direction: column;height: 100%;top: 0;padding-right:20px;font-weight:600;font-size:1.1em}
      .packsUpsell-price > span {padding:0;margin-top:3px;order:1}
      .packsUpsell-comparePrice{font-size:1em}
      .packsUpsell-price-container {order:1;margin-bottom:0}
      .packsUpsell-info{padding-right:85px}
    }
    {% endif %}

    /* active blocks styles */
    .packsUpsell-block.active {box-shadow:inset 0px 0px 0 4px {{ section.settings.color_upsell_active }};transition:box-shadow 0.15s ease 0.1s;}
    .packsUpsell-block.active > label {pointer-events:none}
    .packsUpsell-block.active .packsUpsell-title{color:{{ section.settings.color_title_active }};{% assign brightness = section.settings.color_title_active | color_brightness %}{% if brightness > 225 %}text-shadow: 1px 1px 0px {{ section.settings.color_upsell_active | color_darken: 3 }};{% endif %}}
    .packsUpsell-block.active .packsUpsell-price {color:{{ section.settings.color_price_active }};{% assign brightness = section.settings.color_price_active | color_brightness %}{% if brightness > 225 %}text-shadow: 1px 1px 0px {{ section.settings.color_upsell_active | color_darken: 3 }};{% endif %}}
    .packsUpsell-block.active .packsUpsell-comparePrice {color: {{ section.settings.color_compare_price_active }};}
    .packsUpsell-block.active .packsUpsell-line1 {color:{{ section.settings.color_flash_text_active }};text-shadow: 1px 1px 0px {{ section.settings.color_upsell_active | color_darken: 3 }};}
    .packsUpsell-block.active .packsUpsell-line2{color:{{ section.settings.color_customtext_active }};{% assign brightness = section.settings.color_customtext_active | color_brightness %}{% if brightness > 225 %}text-shadow: 1px 1px 0px {{ section.settings.color_upsell_active | color_darken: 3 }};{% endif %}}
    {% if section.settings.color_style == 'full' %}.packsUpsell-block.active > label {background:{{ section.settings.color_upsell_active }};}{% endif %}

    /* pack description */
    .packsUpsell-block aside {all:unset;display:block;box-sizing:content-box;padding:0px 20px;text-align:left;transition:height .4s ease 0.1s, padding .4s ease 0.1s;overflow: hidden;}
    .packsUpsell-block aside > * {opacity:0;transition: opacity 0.4s ease-out 0.1s}
    .packsUpsell-block:not(.active) aside {height:0px;}
    .packsUpsell-block.active {background-color:{{ section.settings.bgcolor_description_active }};color:{{ section.settings.color_description_active }};}
    .packsUpsell-block.active aside {padding:10px 20px 20px;}
    .packsUpsell-block.active aside > * {opacity:1}
    .packsUpsell-block.active aside ul {padding-left:15px}
    .packsUpsell-block.active aside ul li::before {content:'•';color: {{ section.settings.color_upsell }};font-weight: bold;display: inline-block;width: 1em;margin-left: -1em;}
    .packsUpsell-block aside p {all:unset;display:block;margin:0 0 10px;font-size:0.97em}
    .packsUpsell-block aside p:last-of-type{margin-bottom:0}

    /* variants & properties inside packs */
    .packsUpsell__options, .packsUpsell__properties {display:flex;display:-webkit-flex;flex-wrap:wrap;align-items:flex-end;}
    .packsUpsell__select, .packsUpsell__properties > div {width:50%;margin-bottom:10px}
    .packsUpsell__select select, .packsUpsell__properties select {width:100%;font-size:1em;background-color:rgba(255,255,255,0.85)}
    .packsUpsell__select label {all:unset;font-size:0.95em;}
    .packsUpsell__select:nth-child(2n + 1) {padding-right:10px;}

    /* media queries */
    @media (max-width: {{ breakPoint | minus: 1 }}px){
      #packsUpsell{margin-top:{{ section.settings.spacing_top_mobile }}px;margin-bottom:{{ section.settings.spacing_bottom_mobile }}px;}
      .packsUpsell-block{font-size:{{ font_size_mobile }}em;}
      {% unless section.settings.color_bg contains 'rgba(0,0,0,0)' %}.packsUpsell-tabs {padding:12px;}{% endunless %}
.packsUpsell-input { display:{% unless section.settings.radio_enable_mobile %}none{% else %}block{% endunless %};}
      .packsUpsell-info {line-height:20px;{% unless section.settings.img_enable_mobile %}margin-left:5px;{% else %}margin-left:0;{% endunless %} }
      .packsUpsell-title {font-size:1em}
      .packsUpsell-image{flex:0 0 60px;{% unless section.settings.img_enable_mobile %}display:none;{% else %}display:flex;{% endunless %}}
      .packsUpsell-line1{display:block}
      .packsUpsell-line2 {font-size:1em;}
      {% if mode_mobile == 'ultracompact' %}
      .packsUpsell-line1{display:inline;margin-left:5px}
      {% elsif mode_mobile == 'original' %}
      .packsUpsell-price {padding-right:15px;position: absolute;right: 0;display: flex;align-items: flex-end;justify-content: center;flex-direction: column;height: 100%;top: 0;font-weight:600;font-size:1.1em}
      .packsUpsell-price > span {padding:0;margin-top:3px;order:1}
      .packsUpsell-comparePrice{font-size:1em}
      .packsUpsell-price-container {order:1}
      {% endif %}
    }

    /* custom css */
    @media (min-width:{{section.blocks[developer].settings.query}}px) { {{section.blocks[developer].settings.css_bureau}} }
    @media (max-width:{{section.blocks[developer].settings.query}}px) { {{section.blocks[developer].settings.css_mobile}} }
  </style>

<style>

  .divguarantee{
    display:flex;
    height:45px;
    border: 2px solid;
    border-color: #6cbdfb;
    margin-bottom:25px;
  }
  h2 {
    margin-top:0px!important;
  }
  .slick-arrow {
    color: #00000080;
}
</style>


<div class="product-template__container page-width"
  id="ProductSection-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="product"
  data-enable-history-state="true"
  data-ajax-enabled="{{ settings.enable_ajax }}"
>
  {% comment %}
    Get first variant, or deep linked one
  {% endcomment %}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign product_image_zoom_size = '1024x1024' -%}
  {%- assign product_image_scale = '2' -%}
  {%- assign enable_zoom = section.settings.enable_zoom -%}
  {%- assign compare_at_price = current_variant.compare_at_price -%}
  {%- assign price = current_variant.price -%}

  {% case section.settings.image_size %}
    {% when 'small' %}
      {%- assign product_image_width = 'medium-up--one-third' -%}
      {%- assign product_description_width = 'medium-up--two-thirds' -%}
      {%- assign product_thumbnail_width = 'medium-up--one-third' -%}
      {%- assign height = 345 -%}
    {% when 'medium' %}
      {%- assign product_image_width = 'medium-up--one-half' -%}
      {%- assign product_description_width = 'medium-up--one-half' -%}
      {%- assign product_thumbnail_width = 'medium-up--one-quarter' -%}
      {%- assign height = 530 -%}
    {% when 'large' %}
      {%- assign product_image_width = 'medium-up--two-thirds' -%}
      {%- assign product_description_width = 'medium-up--one-third' -%}
      {%- assign product_thumbnail_width = 'medium-up--one-fifth' -%}
      {%- assign height = 720 -%}
    {% when 'full' %}
      {%- assign product_image_width = '' -%}
      {%- assign product_description_width = '' -%}
      {%- assign product_thumbnail_width = 'medium-up--one-eighth' -%}
      {%- assign height = 1090 -%}
      {%- assign enable_zoom = false -%}
  {% endcase %}

<script type="text/javascript">
