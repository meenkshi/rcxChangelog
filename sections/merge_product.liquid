function submit(e) {
              e.preventDefault();
              e.stopImmediatePropagation();

              if (btn.classList.contains('is-loading')) return;

              btn.disabled = true;
              btn.classList.add('is-loading');

              const activeBlock = document.querySelector('.packsUpsell-block.active');
              if (!activeBlock) return;
              
const dropdowns = activeBlock.querySelectorAll('.js-bundle-variant-row.is-visible .js-bundle-variant-dropdown');

              // Aggregate identical variants
              const itemsMap = new Map();
              dropdowns.forEach(dd => {
                const id = parseInt(dd.value);
                if (itemsMap.has(id)) {
                  itemsMap.set(id, itemsMap.get(id) + 1);
                } else {
                  itemsMap.set(id, 1);
                }
              });

              const itemsToAdd = [];
              itemsMap.forEach((qty, id) => {
                itemsToAdd.push({
                  id: id,
                  quantity: qty
                });
              });

              // Collect gift products if present
              document.querySelectorAll('.js-bundle-gift').forEach(gift => {
                const giftId = parseInt(gift.getAttribute('data-gift-id'));
                if (giftId) {
                  itemsToAdd.push({
                    id: giftId,
                    quantity: 1
                  });
                }
              });

              if (itemsToAdd.length === 0) return;

