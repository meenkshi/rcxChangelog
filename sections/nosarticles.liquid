{% style %}

#shopify-section-{{ section.id }} {
	background-color: {{ section.settings.bg }};
    padding: 50px 0;
}



  @media (min-width:750px){ 
    .h2perso{
        color: #000000;
    	text-transform: uppercase;
    	text-align: center;
    	margin-top: 50px;
    	margin-bottom:30px;
    	font-size: 40px;
      	text-align:center;
    }
  }
  @media (max-width:749px){
    .h2perso{
        color: #000000;
    	text-transform: uppercase;
    	text-align: center;
    	margin-top: 30px;
      	margin-right:10px;
      	margin-left:10px;
        margin-bottom:25px;
      	text-align:center;
      font-size: 25px;
    }
  }

.slick-track {
	padding: 0px 0px;
}

.slider-card {
	box-shadow: 0px 0px 12px #d0d0d0;
	margin: 0 10px;
	padding: 10px;
	background-color: white;
}

.slider-card.img-contain {
	padding: 0;
}

.slider-card:focus, .slick-arrow:focus {
	outline: none;
}

.card-header {
	display: flex;
	align-items: center;
}

.card-name h3, .card-title h3 {
	margin:0;
}

.card-name h3 {
	font-size: 16px;
}

.card-verified {
	margin: 0px 6px;
    background: #718cc8;
    padding: 2px 6px;
    border-radius: 2px;
    color: white;
    font-size: 11px;
    font-weight: 800;
}

.card-title {
    padding-top: 15px;
    font-size: 10px;
}

.slick-prev, .slick-next {
    z-index: 4;
    background: #000000ab;
    width: 70px;
    height: 70px;
    border-radius: 54px;
}

.slick-prev {
	left: 20px;
}

.slick-next {
    right: 20px;
}

.slick-prev:before {
	content: "";
    position: absolute;
    width: 34px;
    height: 34px;
    border-left: 3px solid #fff;
    display: inline-block;
    border-top: 3px solid #fff;
    transform: rotate(-45deg);
    top: 18px;
    left: 23px;
	color: white;
}

.slick-next:before {
	content: "";
    position: absolute;
    width: 34px;
    height: 34px;
    border-right: 3px solid #fff;
    display: inline-block;
    border-top: 3px solid #fff;
    transform: rotate(45deg);
    top: 18px;
    right: 25px;
}

.slick-prev:hover, .slick-prev:focus, .slick-next:hover, .slick-next:focus {
    transition: .2s ease-in-out;
    background: #00000059;
    color: #ffffff00;
}

{% endstyle %}


<div class="page-contain">
  <div class="page-width">
    <h2 class="h2perso">{{ section.settings.sectionname }}</h2>
  </div>
  <div class="review-slider">

    {% for block in section.blocks %}
    <div>
      <div class="slider-card">
        
        <div>
   	  <div class="slider-card img-contain">
        {% if block.settings.imagee %}
        	<img src="{{ block.settings.imagee.src | img_url:'650x'}}" class="slider-img">
        {% else %}
        	{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
        <div class="card-title">
          <h3>{{ block.settings.title }}</h3>
        </div>
        <div class="card-content" style="height:370px">
          <p>{{ block.settings.content }}</p>
        </div>
        <div style="text-align:center;"> 
          <a href="{{ block.settings.linkbtn }}" class="btn" target="_blank" rel="noopener" aria-describedby="a11y-new-window-message">
            {{ block.settings.textbtn }}
          </a>
        </div>
      </div>
    </div>
    
	
    
    {% endfor %}

  </div>
</div>

{% schema %}
{
  "name": "Review Slider",
  "settings": [
    {
      "type": "text",
      "id": "sectionname",
      "label": "Titre de la section",
      "default": "+500,000 utilisateurs actifs dans le monde"
    },
	{
       "type": "color",
       "id": "titlecolor",
       "label": "Couleur du titre",
       "default": "#000000"
    },
	{
       "type": "color",
       "id": "bg",
       "label": "Couleur de fond",
       "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "review",
      "settings": [
		{
          "type": "image_picker",
          "id": "imagee",
          "label": "Image review"
        },
		{
			"type": "text",
			"id": "name",
			"label": "Nom présent sur l'avis",
			"default": "John Doe"
		},
		{
			"type": "text",
			"id": "title",
			"label": "Titre présent sur l'avis",
			"default": "Très bon produit"
		},
        {
			"type": "text",
			"id": "linkbtn",
			"label": "lienbtn",
			"default": "#"
		},
        {
			"type": "text",
			"id": "textbtn",
			"label": "Texte du bouton",
			"default": "Lire la suite"
		},
		{
			"type": "richtext",
			"id": "content",
			"label": "Contenu de l'avis",
			"default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam id velit maximus, porttitor enim eget, aliquet libero. In eu porttitor est, in sodales dui. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae;</p>"
		}
      ]
    }
  ],
  "presets": [
    {
      "name": "BLOG SLIDER",
      "category": "avis"
    }
  ]
}
{% endschema %}