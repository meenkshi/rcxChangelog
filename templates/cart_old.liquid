{% capture cart-content %}{% section 'cart-template-maxdesign' %}{% endcapture %}
{% capture upsell %}{% section 'upsell-maxdesign' %}{% endcapture %}
{% assign upsell = upsell | replace: 'class="shopify-section"', 'class="shopify-section-nested"' %}
