{{ cart-content }}
<!-- Global site tag (gtag.js) - Adwords remarketing by oderajoseph.com -->
<script async src="https://www.googletagmanager.com/gtag/js?id=AW-687353609"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'AW-687353609');
</script>
<script>
  gtag('event', 'page_view', {
    'send_to': 'AW-687353609',
	'ecomm_pagetype': 'cart',
	'ecomm_prodid': [{% for item in cart.items %}'shopify_GB_{{ item.product_id }}_{{ item.variant_id }}',{% endfor %}],
	'ecomm_totalvalue': {{ cart.total_price | money_without_currency | remove:',' }}
  });
</script>
